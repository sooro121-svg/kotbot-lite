    def choose_music_file(self) -> None:
        initial = self.music_folder_path_var.get().strip() or str(PATHS["music"])
        path = filedialog.askopenfilename(
            title="Выбрать музыку",
            initialdir=initial if Path(initial).exists() else str(PATHS["music"]),
            filetypes=[("Аудио", "*.mp3 *.wav *.m4a *.aac *.ogg *.flac *.wma"), ("Все файлы", "*.*")],
        )
        if not path:
            return
        chosen = Path(path)
        if chosen.suffix.lower() not in AUDIO_EXTS:
            messagebox.showwarning(APP_NAME, "Лучше выбрать аудио: MP3, WAV, M4A, AAC, OGG, FLAC или WMA")
            return
        self.music_path_var.set(str(chosen))
        self.music_track_choice_var.set(chosen.name)
        self.music_random_var.set(False)
        self.refresh_music_choices()
        self.refresh_music_label()
        self.on_settings_changed()
