class KotBotApp:
    def __init__(self, root: tk.Tk):
        self.root = root
        self.root.title(APP_NAME)
        self.root.geometry("1480x860")
        self.root.minsize(1220, 740)

        for path in PATHS.values():
            path.mkdir(parents=True, exist_ok=True)

        self.selected_video: Path | None = None
        self.preview_frame_count = 0
        self.preview_fps = 25.0
        self.preview_duration = 0.0
        self._preview_seek_updating = False
        self.selected_photo: Path | None = None
        self.current_photo_bgr = None
        self.photo_preview_image_ref = None
        self.photo_processing = False
        self.photo_worker_settings = None
        self.photo_worker_watermark_image = None
        self.photo_worker_plaque_image = None
        self.photo_watermark_cache_path: Path | None = None
        self.photo_watermark_cache_image: Image.Image | None = None
        self.photo_plaque_cache_path: Path | None = None
        self.photo_plaque_cache_image: Image.Image | None = None
        self.current_frame_bgr = None
        self.preview_cap = None
        self.preview_playing = False
        self.preview_after_id = None
        self.preview_seek_after_id = None
        self.preview_seek_cap = None
        self.preview_seek_cap_path: Path | None = None
        self.preview_image_ref = None
        self.processing = False
        self.worker_settings = None
        self.worker_watermark_image = None
        self.worker_plaque_image = None
        self.watermark_cache_path: Path | None = None
        self.watermark_cache_image: Image.Image | None = None
        self.plaque_cache_path: Path | None = None
        self.plaque_cache_image: Image.Image | None = None
        self.config = self.load_config()
        self.music_tracks_cache: list[Path] = []
        self._settings_save_after_id = None
        self._video_preview_after_id = None
        self._photo_preview_after_id = None
        self._suspend_settings_events = False

        self.setup_vars()
        self.build_ui()
        self.refresh_font_label()
        self.refresh_watermark_label()
        self.refresh_plaque_png_label()
        self.refresh_music_choices()
        self.refresh_music_label()
        self.refresh_photo_font_label()
        self.refresh_photo_watermark_label()
        self.refresh_photo_plaque_png_label()
        self.load_first_video_from_folder(silent=True)
        self.load_first_photo_from_folder(silent=True)
        self.update_preview()
        self.update_photo_preview()
        self.root.protocol("WM_DELETE_WINDOW", self.on_close)

    def setup_vars(self) -> None:
        self.font_size_var = tk.IntVar(value=int(self.config.get("font_size", 46)))
        self.line_spacing_var = tk.IntVar(value=int(self.config.get("line_spacing", 10)))
        self.text_weight_var = tk.IntVar(value=int(self.config.get("text_weight", 0)))
        self.letter_spacing_var = tk.IntVar(value=int(self.config.get("letter_spacing", 0)))
        self.font_family_var = tk.StringVar(value=self.config.get("font_family", "Segoe UI"))
        if self.font_family_var.get() not in available_font_choices():
            self.font_family_var.set("Segoe UI")
        self.font_file_path_var = tk.StringVar(value=self.config.get("font_file_path", ""))
        self.font_label_var = tk.StringVar(value="Шрифт: стандартный")
        self.text_align_var = tk.StringVar(value=self.config.get("text_align", "По центру"))
        if self.text_align_var.get() not in TEXT_ALIGNMENTS:
            self.text_align_var.set("По центру")
        self.text_vertical_var = tk.StringVar(value=self.config.get("text_vertical", "По центру"))
        if self.text_vertical_var.get() not in TEXT_VERTICALS:
            self.text_vertical_var.set("По центру")
        self.text_x_var = tk.IntVar(value=int(self.config.get("text_x", 50)))
