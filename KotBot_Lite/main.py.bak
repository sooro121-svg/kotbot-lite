            self.photo_plaque_png_enabled_var.set(False)
            self.photo_plaque_png_path_var.set("")
            self.photo_plaque_x_var.set(50)
            self.photo_plaque_y_var.set(82)
            self.photo_plaque_width_var.set(72)
            self.photo_plaque_height_var.set(18)
            self.photo_plaque_opacity_var.set(92)
