        self.combo_row(form, 1, "Вертикаль", self.text_vertical_var, TEXT_VERTICALS)
        self.combo_row(form, 2, "Цвет текста", self.text_color_var, list(TEXT_COLOR_DATA.keys()))
        form.columnconfigure(1, weight=1)

        color_row = tk.Frame(box, bg="white")
        color_row.pack(fill="x", padx=12, pady=(0, 8))
        tk.Label(color_row, text="Код цвета", bg="white", fg="#4d463f", font=("Segoe UI", 9)).pack(side="left", padx=(0, 8))
        color_entry = tk.Entry(color_row, textvariable=self.text_custom_color_var, bg="#fbf7f0", bd=1, relief="solid")
        color_entry.pack(side="left", fill="x", expand=True, padx=(0, 6))
        color_entry.bind("<KeyRelease>", lambda _e: (self.text_color_var.set("Свой код"), self.on_settings_changed()))
        color_entry.bind("<FocusOut>", lambda _e: (self.text_color_var.set("Свой код"), self.on_settings_changed()))
        tk.Button(color_row, text="Палитра", command=self.choose_text_color, bg="#eee6dc", relief="flat").pack(side="left")

        tk.Label(
            box,
            text="Для PNG плашки тоже работает: поставь Горизонталь и Вертикаль в режим Вручную, потом двигай X и Y текста внутри плашки.",
            bg="white",
            fg="#665f57",
            font=("Segoe UI", 8),
            wraplength=440,
            justify="left",
        ).pack(anchor="w", padx=12, pady=(0, 4))
        self.slider_row(box, "X текста внутри, %", self.text_x_var, 0, 100)
        self.slider_row(box, "Y текста внутри, %", self.text_y_var, 0, 100)

