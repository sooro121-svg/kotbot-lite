        tk.Button(action_row, text="Копировать", command=self.copy_selected_ai_caption, bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=4)
        tk.Button(action_row, text="Очистить", command=self.clear_ai_variants, bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))

    def get_ai_prompt_text(self) -> str:
        if not hasattr(self, "ai_prompt_text"):
            return str(self.config.get("ai_prompt", ""))
        return self.ai_prompt_text.get("1.0", "end").strip()

    def on_ai_provider_changed(self, *_args) -> None:
        provider = self.ai_provider_var.get()
        default_model = AI_MODEL_DEFAULTS.get(provider, "gemini-2.0-flash")
        current_model = self.ai_model_var.get().strip()
        known_defaults = set(AI_MODEL_DEFAULTS.values()) | {"gpt-4.1-mini", "gemini-2.0-flash", "deepseek-chat", "openrouter/free"}
        if not current_model or current_model in known_defaults:
            self.ai_model_var.set(default_model)
        self.update_ai_provider_hint()
        self.on_settings_changed(preview=False)

    def update_ai_provider_hint(self) -> None:
        if not hasattr(self, "ai_provider_hint_var"):
            return
        provider = self.ai_provider_var.get() if hasattr(self, "ai_provider_var") else "Gemini Free"
        hints = {
            "Gemini Free": "Нужен ключ Google AI Studio. Обычно самый удобный бесплатный вариант для подписей.",
            "OpenRouter Free": "Нужен ключ OpenRouter. Модель openrouter/free сама выбирает бесплатную модель, но бывают лимиты и задержки.",
            "DeepSeek": "Нужен ключ DeepSeek. Обычно дешево и быстро, но это не полностью бесплатный вариант.",
            "OpenAI": "Нужен ключ OpenAI. Если регион не поддерживается, лучше выбрать Gemini или OpenRouter.",
            "Локальный шаблон": "Без ключа и без интернета. Это не настоящая AI, но быстро дает простые заготовки.",
        }
        self.ai_provider_hint_var.set(hints.get(provider, ""))

    def toggle_ai_key_visibility(self) -> None:
        if not hasattr(self, "ai_api_key_entry"):
            return
        current = self.ai_api_key_entry.cget("show")
        self.ai_api_key_entry.configure(show="" if current == "*" else "*")

    def ai_use_current_caption_as_prompt(self) -> None:
        text = self.get_caption().strip()
        if not text:
            text = "милое видео с котом, уютное настроение"
        self.ai_prompt_text.delete("1.0", "end")
        self.ai_prompt_text.insert("1.0", text)
        self.on_settings_changed(preview=False)

    def generate_ai_captions(self) -> None:
        if self.ai_generating:
            return
        provider = self.ai_provider_var.get() if hasattr(self, "ai_provider_var") else "Gemini Free"
        api_key = self.ai_api_key_var.get().strip()
        if provider != "Локальный шаблон" and not api_key:
            messagebox.showwarning("AI подписи", f"Вставь API ключ для {provider} во вкладке AI подписи.")
            return
        prompt_text = self.get_ai_prompt_text().strip()
        if not prompt_text:
            messagebox.showwarning("AI подписи", "Напиши короткое описание сцены или идею.")
            return
        self.ai_generating = True
        self.ai_status_var.set("Генерирую варианты...")
        self.log(f"AI: генерирую варианты подписей через {provider}")
        self.schedule_config_save()
        thread = threading.Thread(target=self.ai_caption_worker, args=(provider, api_key, self.ai_model_var.get().strip(), prompt_text, self.ai_style_var.get(), int(self.ai_count_var.get())), daemon=True)
        thread.start()

    def ai_caption_worker(self, provider: str, api_key: str, model: str, prompt_text: str, style: str, count: int) -> None:
        try:
            count = max(3, min(20, count))
            variants = self.call_ai_captions(provider, api_key, model, prompt_text, style, count)
            self.root.after(0, lambda: self.on_ai_captions_ready(variants, None))
        except Exception as exc:
            self.root.after(0, lambda exc=exc: self.on_ai_captions_ready([], str(exc)))

    def build_ai_caption_prompt(self, prompt_text: str, style: str, count: int) -> str:
        current_public = self.video_public_var.get() if hasattr(self, "video_public_var") else "паблик"
        current_caption = self.get_caption() if hasattr(self, "caption_text") else ""
        filename = self.selected_video.name if self.selected_video else ""
        return (
            "Ты пишешь короткие подписи для VK-паблика с котами. "
            "Нужно придумать варианты на русском языке. "
            "Стиль: мило, живо, без канцелярита, без длинных тире. "
            "Не используй эмодзи, хештеги, кавычки и нумерацию. "
            "Каждая подпись 8-18 слов. "
            "Никаких объяснений, рассуждений, вступлений и строк на английском. "
            f"Верни строго JSON-массив из ровно {count} строк. "
            "Пример формата: [\"Первая подпись\", \"Вторая подпись\"].\n\n"
            f"Паблик: {current_public}\n"
            f"Выбранный стиль: {style}\n"
            f"Описание сцены или идея: {prompt_text}\n"
            f"Текущая подпись, если есть: {current_caption}\n"
            f"Имя файла, если помогает: {filename}"
        )

    def call_ai_captions(self, provider: str, api_key: str, model: str, prompt_text: str, style: str, count: int) -> list[str]:
        provider = provider or "Gemini Free"
        model = model or AI_MODEL_DEFAULTS.get(provider, "gemini-2.0-flash")
        if provider == "Локальный шаблон":
            return self.local_caption_variants(prompt_text, style, count)
        prompt = self.build_ai_caption_prompt(prompt_text, style, count)
        if provider == "Gemini Free":
            text = self.call_gemini_captions(api_key, model, prompt)
        elif provider == "OpenRouter Free":
            text = self.call_chat_completions_captions(
                api_key,
                model or "openrouter/free",
                prompt,
                "https://openrouter.ai/api/v1/chat/completions",
                extra_headers={"HTTP-Referer": "https://kotbot.local", "X-OpenRouter-Title": "KotBot Lite"},
            )
        elif provider == "DeepSeek":
            text = self.call_chat_completions_captions(api_key, model or "deepseek-chat", prompt, "https://api.deepseek.com/chat/completions")
        elif provider == "OpenAI":
            text = self.call_openai_responses_captions(api_key, model or "gpt-4.1-mini", prompt)
        else:
            raise RuntimeError(f"Неизвестный AI провайдер: {provider}")
        variants = self.parse_caption_variants(text)
        if not variants:
            raise RuntimeError("API ответил, но варианты не удалось прочитать")
        return variants[:count]

    def call_gemini_captions(self, api_key: str, model: str, prompt: str) -> str:
        payload = {
            "contents": [{"parts": [{"text": prompt}]}],
            "generationConfig": {"temperature": 0.9, "maxOutputTokens": 700},
        }
        url = f"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={api_key}"
        obj = self.post_json(url, payload, headers={"Content-Type": "application/json"})
        pieces = []
        for cand in obj.get("candidates", []) or []:
            content = cand.get("content", {}) if isinstance(cand, dict) else {}
            for part in content.get("parts", []) or []:
                value = part.get("text") if isinstance(part, dict) else None
                if isinstance(value, str):
                    pieces.append(value)
        return "\n".join(pieces).strip()

    def call_chat_completions_captions(self, api_key: str, model: str, prompt: str, url: str, extra_headers: dict | None = None) -> str:
        payload = {
            "model": model,
            "messages": [{"role": "user", "content": prompt}],
            "temperature": 0.9,
            "max_tokens": 700,
        }
        headers = {"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"}
        if extra_headers:
            headers.update(extra_headers)
        obj = self.post_json(url, payload, headers=headers)
        pieces = []
        for choice in obj.get("choices", []) or []:
            msg = choice.get("message", {}) if isinstance(choice, dict) else {}
            value = msg.get("content")
            if isinstance(value, str):
                pieces.append(value)
        return "\n".join(pieces).strip()

    def call_openai_responses_captions(self, api_key: str, model: str, prompt: str) -> str:
        payload = {"model": model, "input": prompt, "temperature": 0.9, "max_output_tokens": 700}
        obj = self.post_json(
            "https://api.openai.com/v1/responses",
            payload,
            headers={"Content-Type": "application/json", "Authorization": f"Bearer {api_key}"},
        )
        return self.extract_response_text(obj)

    def post_json(self, url: str, payload: dict, headers: dict | None = None) -> dict:
        data = json.dumps(payload, ensure_ascii=False).encode("utf-8")
        req = urllib.request.Request(url, data=data, headers=headers or {"Content-Type": "application/json"}, method="POST")
        try:
            with urllib.request.urlopen(req, timeout=45) as resp:
                raw = resp.read().decode("utf-8", errors="replace")
        except urllib.error.HTTPError as e:
            detail = e.read().decode("utf-8", errors="replace")[:900]
            raise RuntimeError(f"Ошибка API {e.code}: {detail}") from None
        except urllib.error.URLError as e:
            raise RuntimeError(f"Нет соединения с API: {e.reason}") from None
        try:
            return json.loads(raw)
        except Exception:
            raise RuntimeError(f"API вернул не JSON: {raw[:500]}") from None

    def local_caption_variants(self, prompt_text: str, style: str, count: int) -> list[str]:
        base = prompt_text.strip().lower()
        scene = "этот котик"
        if "котен" in base or "котён" in base:
            scene = "этот малыш"
        elif "кошка" in base:
            scene = "эта красавица"
        elif "кот" in base:
            scene = "этот котик"
        starts = [
            "Самое уютное место всегда рядом с теми, кто любит",
            "Кажется, кто-то нашел идеальный уголок для счастья",
            "Тут столько нежности, что хочется говорить шепотом",
            "Когда рядом тепло, весь мир становится мягче",
            "Маленький момент, а улыбка от него на весь день",
            "Вот так выглядит спокойствие, которое хочется забрать себе",
            "Иногда для счастья нужно просто лечь рядом",
            "Такой взгляд умеет растопить даже самый тяжелый день",
            "Если уют имел бы форму, он выглядел бы именно так",
            "Тут явно проходит важная проверка на милоту",
        ]
        funny = [
            "Срочно назначьте этого котика главным по уюту",
            "Планы на день отменены, тут слишком удобно",
            "Когда лег на минутку и случайно стал украшением дня",
            "Уровень важности зашкаливает, а лапки все равно милые",
            "Кажется, кто-то официально занял лучшее место в доме",
        ]
        questions = [
            "А ваш котик тоже выбирает самое уютное место?",
            "Кто еще сейчас захотел так же сладко отдохнуть?",
            "Разве можно пройти мимо такой милоты?",
            "У кого дома живет такой же мастер уюта?",
        ]
        pool = starts[:]
        if "смеш" in style.lower():
            pool = funny + starts
        if "вопрос" in style.lower():
            pool = starts + questions
        variants = []
        for item in pool:
            text = item.replace("этого котика", scene).replace("этот котик", scene)
            if text not in variants:
                variants.append(text)
            if len(variants) >= count:
                return variants
        while len(variants) < count:
            tail = random.choice(questions)
            if tail not in variants:
                variants.append(tail)
        return variants[:count]

    def extract_response_text(self, obj: dict) -> str:
        if isinstance(obj.get("output_text"), str):
            return obj["output_text"]
        pieces = []
        for item in obj.get("output", []) or []:
            if not isinstance(item, dict):
                continue
            for content in item.get("content", []) or []:
                if not isinstance(content, dict):
                    continue
                value = content.get("text") or content.get("content")
                if isinstance(value, str):
                    pieces.append(value)
        return "\n".join(pieces).strip()

    def parse_caption_variants(self, text: str) -> list[str]:
        def cleanup(value: str) -> str:
            line = str(value or "").strip()
            line = line.replace("\r", " ").replace("\n", " ").strip()
            line = re.sub(r"^```(?:json)?", "", line, flags=re.IGNORECASE).strip()
            line = re.sub(r"```$", "", line).strip()
            line = re.sub(r"^(?:line|variant|caption|подпись|вариант)\s*\d+\s*[:.)-]\s*", "", line, flags=re.IGNORECASE).strip()
            line = re.sub(r"^\d+\s*[:.)-]\s*", "", line).strip()
            line = line.lstrip("•*-–— \t").strip()
            line = line.strip('"«»“”')
            line = re.sub(r"\s+", " ", line).strip()
            return line

        def looks_like_caption(line: str) -> bool:
            if not line:
                return False
            low = line.lower()
            bad_phrases = [
                "we need", "let's", "check", "word count", "inclusive", "caption", "captions",
                "russian", "emoji", "hashtags", "quotes", "long dashes", "produce", "craft",
                "return", "json", "array", "format", "варианты:", "вот варианты", "конечно",
            ]
            if any(x in low for x in bad_phrases):
                return False
            cyr = len(re.findall(r"[А-Яа-яЁё]", line))
            lat = len(re.findall(r"[A-Za-z]", line))
            if lat > cyr:
                return False
            words = re.findall(r"[А-Яа-яЁёA-Za-z0-9]+", line)
            if len(words) < 3:
                return False
            if len(line) > 170:
                return False
            return True

        raw_text = str(text or "").strip()
        candidates: list[str] = []

        # Сначала пробуем прочитать нормальный JSON-массив. Так удобнее всего для OpenRouter/Gemini.
        json_chunks = [raw_text]
        left, right = raw_text.find("["), raw_text.rfind("]")
        if left != -1 and right != -1 and right > left:
            json_chunks.append(raw_text[left:right + 1])
        for chunk in json_chunks:
            try:
                obj = json.loads(chunk)
            except Exception:
                continue
            if isinstance(obj, list):
                for item in obj:
                    if isinstance(item, str):
                        candidates.append(item)
                    elif isinstance(item, dict):
                        for key in ("text", "caption", "подпись", "variant"):
                            if isinstance(item.get(key), str):
                                candidates.append(item[key])
                                break
                break

        # Если модель все равно ответила обычным текстом, аккуратно вытаскиваем только строки с подписями.
        if not candidates:
            clean_text = raw_text.replace("```json", "").replace("```", "")
            for raw in clean_text.replace("\r", "\n").split("\n"):
                line = cleanup(raw)
                if line:
                    candidates.append(line)

        result: list[str] = []
        for item in candidates:
            line = cleanup(item)
            if looks_like_caption(line) and line not in result:
                result.append(line)

        # Иногда ответы приходят одной строкой через точку с запятой.
        if len(result) == 1 and ";" in result[0]:
            parts = [cleanup(x) for x in result[0].split(";")]
            result = []
            for part in parts:
                if looks_like_caption(part) and part not in result:
                    result.append(part)
        return result

    def render_ai_variants(self) -> None:
        if not hasattr(self, "ai_variants_inner"):
            return
        for child in self.ai_variants_inner.winfo_children():
            child.destroy()
        self.ai_variant_cards = []
        self.ai_selected_index = None

        if not self.ai_variants:
            tk.Label(
                self.ai_variants_inner,
                text="Тут появятся варианты. Один клик выбирает, двойной клик сразу вставляет.",
                bg="#fbf7f0",
                fg="#665f57",
                font=("Segoe UI", 10),
                justify="left",
                wraplength=420,
            ).pack(fill="x", padx=8, pady=10)
            return

        for i, variant in enumerate(self.ai_variants):
            card = tk.Frame(self.ai_variants_inner, bg="#fffaf2", highlightthickness=1, highlightbackground="#e1d8cc")
            card.pack(fill="x", padx=6, pady=4)
            self.ai_variant_cards.append(card)

            number = tk.Label(card, text=str(i + 1), bg="#eadfce", fg="#3b3128", font=("Segoe UI", 10, "bold"), width=3)
            number.pack(side="left", fill="y")

            text_label = tk.Label(
                card,
                text=variant,
                bg="#fffaf2",
                fg="#28231f",
                font=("Segoe UI", 10),
                justify="left",
                anchor="w",
                wraplength=390,
                padx=8,
                pady=8,
            )
            text_label.pack(side="left", fill="x", expand=True)

            insert_btn = tk.Button(
                card,
                text="Вставить",
                command=lambda idx=i: self.insert_ai_caption_by_index(idx),
                bg="#eee6dc",
                fg="#2e2924",
                relief="flat",
                padx=8,
            )
            insert_btn.pack(side="right", padx=6, pady=6)

            for widget in (card, number, text_label):
                widget.bind("<Button-1>", lambda _e, idx=i: self.select_ai_variant(idx))
                widget.bind("<Double-Button-1>", lambda _e, idx=i: self.insert_ai_caption_by_index(idx))

        self.select_ai_variant(0)

    def select_ai_variant(self, index: int) -> None:
        if index < 0 or index >= len(getattr(self, "ai_variants", [])):
            return
        self.ai_selected_index = index
        for i, card in enumerate(getattr(self, "ai_variant_cards", [])):
            selected = i == index
            bg = "#e8f2e7" if selected else "#fffaf2"
            border = "#2d7d46" if selected else "#e1d8cc"
            try:
                card.configure(bg=bg, highlightbackground=border)
                for child in card.winfo_children():
                    if isinstance(child, tk.Label) and child.cget("width") != 3:
                        child.configure(bg=bg)
                    elif isinstance(child, tk.Button):
                        child.configure(bg="#d8ead6" if selected else "#eee6dc")
            except Exception:
                pass
        try:
            self.ai_status_var.set(f"Выбран вариант {index + 1}. Двойной клик или кнопка вставляет подпись.")
        except Exception:
            pass

    def on_ai_captions_ready(self, variants: list[str], error: str | None) -> None:
        self.ai_generating = False
        if error:
            self.ai_status_var.set("Ошибка генерации")
            self.log(f"AI ошибка: {error}")
            messagebox.showerror("AI подписи", error)
            return
        self.ai_variants = variants
        self.render_ai_variants()
        self.ai_status_var.set(f"Готово: {len(variants)} вариантов. Один клик выбирает, двойной клик вставляет.")
        self.log(f"AI: готово вариантов: {len(variants)}")

    def selected_ai_caption(self) -> str:
        variants = getattr(self, "ai_variants", [])
        index = getattr(self, "ai_selected_index", None)
        if index is not None and 0 <= index < len(variants):
            return variants[index].strip()
        if hasattr(self, "ai_variants_list"):
            selection = self.ai_variants_list.curselection()
            if selection:
                return self.ai_variants_list.get(selection[0]).strip()
        return ""

    def insert_ai_caption_by_index(self, index: int) -> None:
        self.select_ai_variant(index)
        self.insert_selected_ai_caption()

    def insert_selected_ai_caption(self) -> None:
        text = self.selected_ai_caption()
        if not text:
            messagebox.showinfo("AI подписи", "Сначала выбери вариант из списка.")
            return
        self.caption_text.delete("1.0", "end")
        self.caption_text.insert("1.0", text)
        self.on_settings_changed()
        self.log("AI: выбранная подпись вставлена")

    def copy_selected_ai_caption(self) -> None:
        text = self.selected_ai_caption()
        if not text:
            messagebox.showinfo("AI подписи", "Сначала выбери вариант из списка.")
            return
        self.root.clipboard_clear()
        self.root.clipboard_append(text)
        self.ai_status_var.set("Вариант скопирован")

    def clear_ai_variants(self) -> None:
        self.ai_variants = []
        if hasattr(self, "ai_variants_list"):
            self.ai_variants_list.delete(0, "end")
        self.render_ai_variants()
        self.ai_status_var.set("Список очищен")

