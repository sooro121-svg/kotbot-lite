    def settings_notebook(self, parent: tk.Widget) -> None:
        notebook = ttk.Notebook(parent)
        notebook.pack(fill="both", expand=True, pady=(0, 8))

        public_tab = self.scrollable_tab(notebook, "Паблики")
        self.public_controls(public_tab, "video")

        folders_tab = self.scrollable_tab(notebook, "Папки")
        self.folder_big_buttons(folders_tab)

        text_tab = self.scrollable_tab(notebook, "Текст")
        self.text_controls(text_tab)

        ai_tab = self.scrollable_tab(notebook, "AI подписи")
        self.ai_caption_controls(ai_tab)

        plaque_tab = self.scrollable_tab(notebook, "Плашка")
        self.plaque_controls(plaque_tab)

        watermark_tab = self.scrollable_tab(notebook, "Watermark")
        self.watermark_controls(watermark_tab)

        video_tab = self.scrollable_tab(notebook, "Видео")
        self.video_filter_controls(video_tab)

        music_tab = self.scrollable_tab(notebook, "Музыка")
        self.music_controls(music_tab)

        random_tab = self.scrollable_tab(notebook, "Рандом")
        self.randomization_controls(random_tab)

    def scrollable_tab(self, notebook: ttk.Notebook, title: str) -> tk.Frame:
        holder = tk.Frame(notebook, bg="#f4f1ea")
        notebook.add(holder, text=title)

        canvas = tk.Canvas(holder, bg="#f4f1ea", highlightthickness=0)
        scrollbar = ttk.Scrollbar(holder, orient="vertical", command=canvas.yview)
        scroll_frame = tk.Frame(canvas, bg="#f4f1ea")
        window_id = canvas.create_window((0, 0), window=scroll_frame, anchor="nw")

        def on_configure(_event=None):
            canvas.configure(scrollregion=canvas.bbox("all"))
            canvas.itemconfigure(window_id, width=canvas.winfo_width())

        def on_mousewheel(event):
            if platform.system() == "Darwin":
                canvas.yview_scroll(int(-event.delta), "units")
            else:
                canvas.yview_scroll(int(-event.delta / 120), "units")

        def bind_mousewheel(_event=None):
            canvas.bind_all("<MouseWheel>", on_mousewheel)

        def unbind_mousewheel(_event=None):
            canvas.unbind_all("<MouseWheel>")

        scroll_frame.bind("<Configure>", on_configure)
        canvas.bind("<Configure>", on_configure)
        canvas.bind("<Enter>", bind_mousewheel)
        canvas.bind("<Leave>", unbind_mousewheel)
        canvas.configure(yscrollcommand=scrollbar.set)
        canvas.pack(side="left", fill="both", expand=True)
        scrollbar.pack(side="right", fill="y")
        return scroll_frame

    def public_names(self) -> list[str]:
        return list(getattr(self, "public_presets", {"Хвостик": {}}).keys())

    def public_slug(self, name: str) -> str:
        return slugify_public_name(name)

    def public_base_folder(self, media: str | None = None) -> Path:
        name = self.selected_public_name(media or "video")
        return self.ensure_public_folders(name)

    def public_output_folder(self, media: str) -> Path:
        name = self.selected_public_name(media)
        base = self.ensure_public_folders(name)
        folder = base / ("готовые_видео" if media == "video" else "готовые_фото")
        folder.mkdir(parents=True, exist_ok=True)
        return folder

    def ensure_public_folders(self, name: str) -> Path:
        slug = self.public_slug(name)
        base = PATHS["publics"] / slug
        for sub in ("готовые_видео", "готовые_фото"):
            (base / sub).mkdir(parents=True, exist_ok=True)
        return base

    def next_public_output_file(self, media: str, suffix: str) -> Path:
        folder = self.public_output_folder(media)
        public = self.selected_public_name(media)
        slug = self.public_slug(public)
        today = time.strftime("%Y%m%d")
        prefix = f"{slug}_{today}"
        max_num = 0
        try:
            for existing in folder.glob(f"{prefix}_*{suffix}"):
                tail = existing.stem.replace(prefix + "_", "", 1)
                if tail.isdigit():
                    max_num = max(max_num, int(tail))
        except Exception:
            pass
        return folder / f"{prefix}_{max_num + 1:03d}{suffix}"

    def public_controls(self, parent: tk.Widget, media: str) -> None:
        box = self.card(parent)
        box.pack(fill="x", pady=(0, 10))
        title = "Паблики видео" if media == "video" else "Паблики фото"
        tk.Label(box, text=title, font=("Segoe UI", 12, "bold"), bg="white", fg="#28231f").pack(anchor="w", padx=12, pady=(10, 8))

        hint = "У каждого паблика свои настройки и своя папка готовых файлов для VK. Выбираешь паблик - готовое будет сохраняться именно в его папку."
        tk.Label(box, text=hint, bg="white", fg="#665f57", font=("Segoe UI", 8), wraplength=460, justify="left").pack(anchor="w", padx=12, pady=(0, 6))

        form = tk.Frame(box, bg="white")
        form.pack(fill="x", padx=12, pady=(0, 8))
        var = self.video_public_var if media == "video" else self.photo_public_var
        combo = self.combo_row(form, 0, "Паблик", var, self.public_names(), on_change=lambda: self.on_public_choice_changed(media))
        form.columnconfigure(1, weight=1)
        if media == "video":
            self.video_public_combo = combo
        else:
            self.photo_public_combo = combo

        row1 = tk.Frame(box, bg="white")
        row1.pack(fill="x", padx=10, pady=(0, 6))
        tk.Button(row1, text="Применить", command=lambda: self.apply_public_preset(media), bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(0, 4))
        tk.Button(row1, text="Сохранить в паблик", command=lambda: self.save_current_public_preset(media), bg="#2d7d46", fg="white", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))

        row2 = tk.Frame(box, bg="white")
        row2.pack(fill="x", padx=10, pady=(0, 6))
        tk.Button(row2, text="Добавить паблик", command=lambda: self.add_public_preset(media), bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(0, 4))
        tk.Button(row2, text="Удалить", command=lambda: self.delete_public_preset(media), bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))

        row3 = tk.Frame(box, bg="white")
        row3.pack(fill="x", padx=10, pady=(0, 10))
        tk.Button(row3, text="Открыть готовые паблика", command=lambda: self.open_folder(self.public_output_folder(media)), bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(0, 4))
        tk.Button(row3, text="Открыть папку паблика", command=lambda: self.open_folder(self.public_base_folder(media)), bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))

    def refresh_public_combos(self) -> None:
        names = self.public_names()
        if hasattr(self, "video_public_combo"):
            self.video_public_combo.configure(values=names)
        if hasattr(self, "photo_public_combo"):
            self.photo_public_combo.configure(values=names)

    def selected_public_name(self, media: str) -> str:
        var = self.video_public_var if media == "video" else self.photo_public_var
        name = var.get().strip()
        if name not in self.public_presets:
            name = self.public_names()[0]
            var.set(name)
        return name

    def on_public_choice_changed(self, media: str) -> None:
        name = self.selected_public_name(media)
        self.ensure_public_folders(name)
        if media == "video":
            self.config["current_video_public"] = name
        else:
            self.config["current_photo_public"] = name
        preset = self.public_presets.get(name, {}).get(media, {})
        if preset:
            self.apply_public_preset(media, show_message=False)
        else:
            self.schedule_config_save()
            if media == "video":
                self.status_var.set(f"Паблик выбран: {name}")
            else:
                self.photo_status_var.set(f"Паблик выбран: {name}")

    def collect_video_preset_values(self) -> dict:
        settings = self.collect_settings(randomize=False)
        settings.pop("caption", None)
        settings.pop("random_used", None)
        return settings

    def collect_photo_preset_values(self) -> dict:
        settings = self.collect_photo_settings(randomize=False)
        settings.pop("caption", None)
        settings.pop("photo_random_used", None)
        return settings

    def save_current_public_preset(self, media: str) -> None:
        name = self.selected_public_name(media)
        preset = self.public_presets.setdefault(name, {"video": {}, "photo": {}})
        if media == "video":
            preset["video"] = self.collect_video_preset_values()
            self.status_var.set(f"Настройки видео сохранены: {name}")
            self.log(f"Паблик {name}: настройки видео сохранены")
        else:
            preset["photo"] = self.collect_photo_preset_values()
            self.photo_status_var.set(f"Настройки фото сохранены: {name}")
            self.photo_log(f"Паблик {name}: настройки фото сохранены")
        self.save_config()

    def add_public_preset(self, media: str) -> None:
        name = simpledialog.askstring(APP_NAME, "Название паблика:", parent=self.root)
        if not name:
            return
        name = name.strip()
        if not name:
            return
        if name in self.public_presets:
            messagebox.showinfo(APP_NAME, "Такой паблик уже есть")
            return
        self.public_presets[name] = {"video": {}, "photo": {}}
        self.ensure_public_folders(name)
        if media == "video":
            self.video_public_var.set(name)
        else:
            self.photo_public_var.set(name)
        self.refresh_public_combos()
        self.save_current_public_preset(media)

    def delete_public_preset(self, media: str) -> None:
        if len(self.public_presets) <= 1:
            messagebox.showinfo(APP_NAME, "Нужен хотя бы один паблик")
            return
        name = self.selected_public_name(media)
        if not messagebox.askyesno(APP_NAME, f"Удалить паблик {name}?"):
            return
        self.public_presets.pop(name, None)
        first = self.public_names()[0]
        if self.video_public_var.get() == name:
            self.video_public_var.set(first)
        if self.photo_public_var.get() == name:
            self.photo_public_var.set(first)
        self.refresh_public_combos()
        self.save_config()
        self.on_public_choice_changed(media)

    def apply_public_preset(self, media: str, show_message: bool = True) -> None:
        name = self.selected_public_name(media)
        preset = self.public_presets.get(name, {}).get(media, {})
        if not preset:
            if show_message:
                messagebox.showinfo(APP_NAME, "В этом паблике пока нет сохраненных настроек")
            return
        self._suspend_settings_events = True
        try:
            if media == "video":
                self.apply_video_preset_values(preset)
                self.refresh_watermark_label()
                self.refresh_plaque_png_label()
                self.refresh_font_label()
                self.refresh_music_choices()
                self.refresh_music_label()
            else:
                self.apply_photo_preset_values(preset)
                self.refresh_photo_watermark_label()
                self.refresh_photo_plaque_png_label()
                self.refresh_photo_font_label()
        finally:
            self._suspend_settings_events = False
        self.on_settings_changed()
        if media == "video":
            self.status_var.set(f"Применен паблик: {name}")
            self.log(f"Применен паблик видео: {name}")
        else:
            self.photo_status_var.set(f"Применен паблик: {name}")
            self.photo_log(f"Применен паблик фото: {name}")

    def apply_video_preset_values(self, preset: dict) -> None:
        var_map = {
            "font_size": self.font_size_var,
            "line_spacing": self.line_spacing_var,
            "text_weight": self.text_weight_var,
            "letter_spacing": self.letter_spacing_var,
            "font_family": self.font_family_var,
            "font_file_path": self.font_file_path_var,
            "text_align": self.text_align_var,
            "text_vertical": self.text_vertical_var,
            "text_x": self.text_x_var,
            "text_y": self.text_y_var,
            "text_color": self.text_color_var,
            "text_custom_color": self.text_custom_color_var,
            "text_stroke": self.text_stroke_var,
            "text_shadow": self.text_shadow_var,
            "plaque_enabled": self.plaque_enabled_var,
            "plaque_position": self.plaque_position_var,
            "style": self.style_var,
            "plaque_png_enabled": self.plaque_png_enabled_var,
            "plaque_png_path": self.plaque_png_path_var,
            "plaque_x": self.plaque_x_var,
            "plaque_y": self.plaque_y_var,
            "plaque_width": self.plaque_width_var,
            "plaque_height": self.plaque_height_var,
            "plaque_opacity": self.plaque_opacity_var,
            "plaque_radius": self.plaque_radius_var,
            "plaque_border": self.plaque_border_var,
            "plaque_pad_x": self.plaque_pad_x_var,
            "plaque_pad_y": self.plaque_pad_y_var,
            "watermark_enabled": self.watermark_enabled_var,
            "watermark_path": self.watermark_path_var,
            "watermark_size": self.watermark_size_var,
            "watermark_opacity": self.watermark_opacity_var,
            "watermark_position": self.watermark_position_var,
            "watermark_x": self.watermark_x_var,
            "watermark_y": self.watermark_y_var,
            "watermark_margin": self.watermark_margin_var,
            "brightness": self.brightness_var,
            "contrast": self.contrast_var,
            "saturation": self.saturation_var,
            "sharpness": self.sharpness_var,
            "mirror": self.mirror_var,
            "export_quality": self.export_quality_var,
            "video_scale": self.video_scale_var,
            "random_video": self.random_video_var,
            "random_brightness": self.random_brightness_var,
            "random_contrast": self.random_contrast_var,
            "random_saturation": self.random_saturation_var,
            "random_sharpness": self.random_sharpness_var,
            "random_video_scale": self.random_video_scale_var,
            "random_mirror": self.random_mirror_var,
            "preview_fast": self.preview_fast_var,
            "vk_safe_zones": self.vk_safe_zones_var,
            "music_enabled": self.music_enabled_var,
            "music_random": self.music_random_var,
            "music_folder_path": self.music_folder_path_var,
            "music_path": self.music_path_var,
            "music_track_choice": self.music_track_choice_var,
            "original_volume": self.original_volume_var,
            "music_volume": self.music_volume_var,
        }
        for key, var in var_map.items():
            if key in preset:
                try:
                    var.set(preset[key])
                except Exception:
                    pass
        self.watermark_cache_path = None
        self.watermark_cache_image = None
        self.plaque_cache_path = None
        self.plaque_cache_image = None

    def apply_photo_preset_values(self, preset: dict) -> None:
        var_map = {
            "photo_export_quality": self.photo_export_quality_var,
            "font_size": self.photo_font_size_var,
            "line_spacing": self.photo_line_spacing_var,
            "text_weight": self.photo_text_weight_var,
            "letter_spacing": self.photo_letter_spacing_var,
            "font_family": self.photo_font_family_var,
            "font_file_path": self.photo_font_file_path_var,
            "text_align": self.photo_text_align_var,
            "text_vertical": self.photo_text_vertical_var,
            "text_x": self.photo_text_x_var,
            "text_y": self.photo_text_y_var,
            "text_color": self.photo_text_color_var,
            "text_custom_color": self.photo_text_custom_color_var,
            "text_stroke": self.photo_text_stroke_var,
            "text_shadow": self.photo_text_shadow_var,
            "plaque_enabled": self.photo_plaque_enabled_var,
            "plaque_position": self.photo_plaque_position_var,
            "style": self.photo_style_var,
            "plaque_png_enabled": self.photo_plaque_png_enabled_var,
            "plaque_png_path": self.photo_plaque_png_path_var,
            "plaque_x": self.photo_plaque_x_var,
            "plaque_y": self.photo_plaque_y_var,
            "plaque_width": self.photo_plaque_width_var,
            "plaque_height": self.photo_plaque_height_var,
            "plaque_opacity": self.photo_plaque_opacity_var,
            "plaque_radius": self.photo_plaque_radius_var,
            "plaque_border": self.photo_plaque_border_var,
            "plaque_pad_x": self.photo_plaque_pad_x_var,
            "plaque_pad_y": self.photo_plaque_pad_y_var,
            "watermark_enabled": self.photo_watermark_enabled_var,
            "watermark_path": self.photo_watermark_path_var,
            "watermark_size": self.photo_watermark_size_var,
            "watermark_opacity": self.photo_watermark_opacity_var,
            "watermark_position": self.photo_watermark_position_var,
            "watermark_x": self.photo_watermark_x_var,
            "watermark_y": self.photo_watermark_y_var,
            "watermark_margin": self.photo_watermark_margin_var,
            "photo_random_enabled": self.photo_random_enabled_var,
        }
        for key in PHOTO_FILTER_SPECS:
            var_map[key] = self.photo_filter_vars[key]
            var_map[f"random_{key}"] = self.photo_random_range_vars[key]
        for key, var in var_map.items():
            if key in preset:
                try:
                    var.set(preset[key])
                except Exception:
                    pass
        self.photo_watermark_cache_path = None
        self.photo_watermark_cache_image = None
        self.photo_plaque_cache_path = None
        self.photo_plaque_cache_image = None

