    def choose_music_folder(self) -> None:
        initial = self.music_folder_path_var.get().strip() or str(PATHS["music"])
        path = filedialog.askdirectory(title="Выбрать папку с музыкой", initialdir=initial if Path(initial).exists() else str(PATHS["music"]))
        if not path:
            return
        self.music_folder_path_var.set(str(Path(path)))
        self.refresh_music_choices()
        self.refresh_music_label()
        self.on_settings_changed()
        self.log(f"Папка музыки: {path}")

    def music_track_choices(self) -> list[str]:
        folder_text = self.music_folder_path_var.get().strip() if hasattr(self, "music_folder_path_var") else ""
        folder = Path(folder_text) if folder_text else PATHS["music"]
        if not folder.exists() or not folder.is_dir():
            folder = PATHS["music"]
        try:
            tracks = sorted([p for p in folder.iterdir() if p.is_file() and p.suffix.lower() in AUDIO_EXTS], key=lambda p: p.name.lower())
        except Exception:
            tracks = []
        self.music_tracks_cache = tracks
        values = ["Не выбрано"] + [p.name for p in tracks]
        path_text = self.music_path_var.get().strip() if hasattr(self, "music_path_var") else ""
        if path_text:
            path = Path(path_text)
            if path.exists() and path.suffix.lower() in AUDIO_EXTS and path.name not in values:
                values.append(path.name)
        return values

    def refresh_music_choices(self) -> None:
        values = self.music_track_choices()
        if hasattr(self, "music_combo"):
            self.music_combo.configure(values=values)
        current = self.music_track_choice_var.get().strip() if hasattr(self, "music_track_choice_var") else ""
        path_text = self.music_path_var.get().strip() if hasattr(self, "music_path_var") else ""
        if current in values:
            return
        if path_text and Path(path_text).name in values:
            self.music_track_choice_var.set(Path(path_text).name)
        else:
            self.music_track_choice_var.set("Не выбрано")

    def refresh_music_choices_clicked(self) -> None:
        self.refresh_music_choices()
        self.refresh_music_label()
        self.on_settings_changed()
        count = len(getattr(self, "music_tracks_cache", []))
        self.log(f"Список музыки обновлен: {count} треков")

    def on_music_choice_changed(self) -> None:
        choice = self.music_track_choice_var.get().strip()
        if not choice or choice == "Не выбрано":
            self.music_path_var.set("")
        else:
            track = self.find_music_track_by_name(choice)
            if track is not None:
                self.music_path_var.set(str(track))
                self.music_random_var.set(False)
        self.refresh_music_label()
        self.on_settings_changed()

    def find_music_track_by_name(self, name: str) -> Path | None:
        target = str(name or "").strip()
        if not target or target == "Не выбрано":
            return None
        folder_text = self.music_folder_path_var.get().strip() if hasattr(self, "music_folder_path_var") else ""
        folder = Path(folder_text) if folder_text else PATHS["music"]
        path = folder / target
        if path.exists() and path.suffix.lower() in AUDIO_EXTS:
            return path
        path_text = self.music_path_var.get().strip() if hasattr(self, "music_path_var") else ""
        if path_text:
            path = Path(path_text)
            if path.exists() and path.name == target and path.suffix.lower() in AUDIO_EXTS:
                return path
        return None

    def pick_music_from_folder(self) -> None:
        track = self.pick_music_track(random_choice=False)
        if track is None:
            messagebox.showinfo(APP_NAME, "В папке музыки нет аудиофайлов")
            return
        self.music_path_var.set(str(track))
        self.music_track_choice_var.set(track.name)
        self.music_random_var.set(False)
        self.refresh_music_choices()
        self.refresh_music_label()
        self.on_settings_changed()
        self.log(f"Взят трек из папки: {track.name}")

    def clear_music_file(self) -> None:
        self.music_path_var.set("")
        self.music_track_choice_var.set("Не выбрано")
        self.refresh_music_choices()
        self.refresh_music_label()
        self.on_settings_changed()
        self.log("Музыка очищена")

    def refresh_music_label(self) -> None:
        path_text = self.music_path_var.get().strip() if hasattr(self, "music_path_var") else ""
        folder_text = self.music_folder_path_var.get().strip() if hasattr(self, "music_folder_path_var") else str(PATHS["music"])
        count = len(getattr(self, "music_tracks_cache", []))
        if path_text:
            self.music_label_var.set(f"Трек: {Path(path_text).name} | Папка: {Path(folder_text).name} | В списке: {count}")
        else:
            self.music_label_var.set(f"Трек не выбран | Папка: {Path(folder_text).name} | В списке: {count}")

    def pick_music_track(self, random_choice: bool = True, folder_path: str | None = None) -> Path | None:
        if folder_path is None:
            folder_text = self.music_folder_path_var.get().strip() if hasattr(self, "music_folder_path_var") else ""
        else:
            folder_text = str(folder_path).strip()
        folder = Path(folder_text) if folder_text else PATHS["music"]
        if not folder.exists() or not folder.is_dir():
            folder = PATHS["music"]
        try:
            tracks = sorted([p for p in folder.iterdir() if p.is_file() and p.suffix.lower() in AUDIO_EXTS], key=lambda p: p.name.lower())
        except Exception:
            tracks = []
        if not tracks:
            return None
        return random.choice(tracks) if random_choice else tracks[0]

    def resolve_music_track(self, settings: dict | None) -> Path | None:
        settings = settings or {}
        if not settings.get("music_enabled"):
            return None
        if settings.get("music_random"):
            track = self.pick_music_track(random_choice=True, folder_path=str(settings.get("music_folder_path", "")))
        else:
            path_text = str(settings.get("music_path", "")).strip()
            track = Path(path_text) if path_text else None
            if track is None or not track.exists():
                choice = str(settings.get("music_track_choice", "")).strip()
                track = self.find_music_track_by_name(choice)
        if track is None or not track.exists() or track.suffix.lower() not in AUDIO_EXTS:
            self.safe_log("Музыка включена, но трек не найден")
            return None
        return track

    def reset_video_filters(self) -> None:
        self.brightness_var.set(0)
        self.contrast_var.set(100)
        self.saturation_var.set(100)
        self.sharpness_var.set(0)
        self.mirror_var.set(False)
        self.on_settings_changed()
        self.log("Фильтры видео сброшены")

    def set_preview_seek(self, percent: int, frame_index: int | None = None) -> None:
        if not hasattr(self, "preview_seek_var"):
            return
        self._preview_seek_updating = True
        self.preview_seek_var.set(clamp(int(percent), 0, 100))
        self._preview_seek_updating = False
        self.update_preview_seek_label(frame_index)

    def update_preview_seek_label(self, frame_index: int | None = None) -> None:
        if not hasattr(self, "preview_time_var"):
            return
        if frame_index is None:
            percent = self.preview_seek_var.get() if hasattr(self, "preview_seek_var") else 0
            frame_index = int(percent * max(self.preview_frame_count - 1, 0) / 100) if self.preview_frame_count > 1 else 0
        current_seconds = (frame_index / self.preview_fps) if self.preview_fps else 0
        self.preview_time_var.set(f"{format_time(current_seconds)} / {format_time(self.preview_duration)}")

    def on_preview_seek(self, value) -> None:
        if self._preview_seek_updating:
            return
        if not self.selected_video or self.preview_frame_count <= 0:
            self.update_preview_seek_label(0)
            return
        if self.preview_playing:
            self.preview_playing = False
            if self.preview_after_id:
                try:
                    self.root.after_cancel(self.preview_after_id)
                except Exception:
                    pass
                self.preview_after_id = None
            self.close_preview_cap(release_seek=False)
        percent = int(float(value))
        frame_index = int(percent * max(self.preview_frame_count - 1, 0) / 100)
        self.update_preview_seek_label(frame_index)
        self.schedule_preview_seek(frame_index, delay=120)

    def on_preview_seek_release(self, _event=None) -> None:
        if not self.selected_video or self.preview_frame_count <= 0:
            return
        frame_index = int(self.preview_seek_var.get() * max(self.preview_frame_count - 1, 0) / 100)
        self.schedule_preview_seek(frame_index, delay=1)

    def schedule_preview_seek(self, frame_index: int, delay: int = 120) -> None:
        if self.preview_seek_after_id:
            try:
                self.root.after_cancel(self.preview_seek_after_id)
            except Exception:
                pass
            self.preview_seek_after_id = None
        self.preview_seek_after_id = self.root.after(delay, lambda idx=frame_index: self.load_preview_seek_frame(idx))

    def load_preview_seek_frame(self, frame_index: int) -> None:
        self.preview_seek_after_id = None
        if not self.selected_video:
            return
        self.load_frame_from_video(self.selected_video, frame_index=frame_index)
        self.update_preview()

    def scaled_preview_settings(self, settings: dict, scale: float) -> dict:
        if scale >= 0.995:
            return settings
        scaled = dict(settings)
        for key in ("font_size", "line_spacing", "letter_spacing", "text_stroke", "text_weight", "plaque_border"):
            if key in scaled:
                value = int(scaled.get(key, 0))
                if key == "font_size":
                    scaled[key] = max(10, int(value * scale))
                elif key == "plaque_border":
                    scaled[key] = max(1, int(value * scale)) if value > 0 else 0
                else:
                    scaled[key] = max(0, int(value * scale))
        return scaled

    def render_preview_frame(self, frame_bgr: np.ndarray, settings: dict, watermark_image: Image.Image | None, plaque_image: Image.Image | None) -> np.ndarray:
        if not self.preview_fast_var.get():
            return self.render_frame(frame_bgr, settings, watermark_image=watermark_image, plaque_image=plaque_image)
        h, w = frame_bgr.shape[:2]
        target_w, target_h = self.video_output_size(w, h, settings)
        max_w, max_h = 820, 540
        scale = min(max_w / max(1, target_w), max_h / max(1, target_h), 1.0)
        if scale < 0.995:
            preview_w = max(2, int(target_w * scale))
            preview_h = max(2, int(target_h * scale))
            scaled_settings = self.scaled_preview_settings(settings, scale)
            scaled_settings["output_width"] = preview_w
            scaled_settings["output_height"] = preview_h
            return self.render_frame(frame_bgr, scaled_settings, watermark_image=watermark_image, plaque_image=plaque_image)
        return self.render_frame(frame_bgr, settings, watermark_image=watermark_image, plaque_image=plaque_image)

    def update_preview(self, frame_bgr=None) -> None:
        if not hasattr(self, "preview_label"):
            return
        if frame_bgr is None:
            frame_bgr = self.current_frame_bgr
        if frame_bgr is None:
            self.preview_label.configure(image="", text="Пока нет видео")
            self.set_preview_seek(0, 0)
            return

        settings = self.collect_settings(randomize=False)
        rendered = self.render_preview_frame(frame_bgr, settings, watermark_image=self.load_watermark_image(settings), plaque_image=self.load_plaque_image(settings))
        rgb = cv2.cvtColor(rendered, cv2.COLOR_BGR2RGB)
        img = Image.fromarray(rgb)
        if settings.get("vk_safe_zones"):
            img = self.draw_vk_safe_zones(img)
        if not self.preview_fast_var.get():
            img.thumbnail((920, 560), Image.Resampling.BILINEAR)
        photo = ImageTk.PhotoImage(img)
        self.preview_image_ref = photo
        self.preview_label.configure(image=photo, text="")

    def draw_vk_safe_zones(self, img: Image.Image) -> Image.Image:
        overlay = img.convert("RGBA")
        draw = ImageDraw.Draw(overlay, "RGBA")
        w, h = overlay.size
        # Верх и низ - примерные зоны интерфейса VK клипов/ленты. Это только предпросмотр, в экспорт не попадает.
        top_h = int(h * 0.09)
        bottom_h = int(h * 0.16)
        side_w = int(w * 0.08)
        draw.rectangle([0, 0, w, top_h], outline=(255, 255, 255, 150), width=max(1, w // 180))
        draw.rectangle([0, h - bottom_h, w, h], outline=(255, 255, 255, 150), width=max(1, w // 180))
        draw.rectangle([0, 0, side_w, h], outline=(255, 255, 255, 80), width=max(1, w // 220))
        draw.rectangle([w - side_w, 0, w, h], outline=(255, 255, 255, 80), width=max(1, w // 220))
        draw.line([0, int(h * 0.5), w, int(h * 0.5)], fill=(255, 255, 255, 80), width=1)
        draw.line([int(w * 0.5), 0, int(w * 0.5), h], fill=(255, 255, 255, 80), width=1)
        return overlay.convert("RGB")

    def toggle_preview_play(self) -> None:
        if not self.selected_video:
            messagebox.showinfo(APP_NAME, "Сначала выбери видео")
            return
        self.preview_playing = not self.preview_playing
        if self.preview_playing:
            if self.preview_seek_after_id:
                try:
                    self.root.after_cancel(self.preview_seek_after_id)
                except Exception:
                    pass
                self.preview_seek_after_id = None
            self.close_preview_cap(release_seek=True)
            self.preview_cap = cv2.VideoCapture(str(self.selected_video))
            if self.preview_frame_count > 1:
                start_frame = int(self.preview_seek_var.get() * max(self.preview_frame_count - 1, 0) / 100)
                self.preview_cap.set(cv2.CAP_PROP_POS_FRAMES, start_frame)
            self.preview_tick()
        else:
            if self.preview_after_id:
                self.root.after_cancel(self.preview_after_id)
                self.preview_after_id = None
            self.close_preview_cap(release_seek=False)

    def preview_tick(self) -> None:
        if not self.preview_playing or self.preview_cap is None:
            return
        ok, frame = self.preview_cap.read()
        if not ok:
            self.preview_cap.set(cv2.CAP_PROP_POS_FRAMES, 0)
            ok, frame = self.preview_cap.read()
        if ok:
            self.current_frame_bgr = frame
            current_frame = int(self.preview_cap.get(cv2.CAP_PROP_POS_FRAMES) or 0) - 1
            percent = int(current_frame * 100 / max(self.preview_frame_count - 1, 1)) if self.preview_frame_count > 1 else 0
            self.set_preview_seek(percent, current_frame)
            self.update_preview(frame)
        fps = self.preview_fps if self.preview_fps and self.preview_fps > 0 else 25.0
        delay = int(1000 / min(max(fps, 1.0), 18.0))
        self.preview_after_id = self.root.after(max(45, delay), self.preview_tick)

    def close_preview_cap(self, release_seek: bool = True) -> None:
        if self.preview_cap is not None:
            self.preview_cap.release()
            self.preview_cap = None
        if release_seek and self.preview_seek_cap is not None:
            self.preview_seek_cap.release()
            self.preview_seek_cap = None
            self.preview_seek_cap_path = None

    def get_preview_seek_cap(self, path: Path):
        try:
            resolved = path.resolve()
        except Exception:
            resolved = path
        if self.preview_seek_cap is not None and self.preview_seek_cap_path == resolved:
            return self.preview_seek_cap
        if self.preview_seek_cap is not None:
            self.preview_seek_cap.release()
        cap = cv2.VideoCapture(str(path))
        if not cap.isOpened():
            self.preview_seek_cap = None
            self.preview_seek_cap_path = None
            return None
        self.preview_seek_cap = cap
        self.preview_seek_cap_path = resolved
        return cap

    def collect_settings(self, randomize: bool = False) -> dict:
        settings = {
            "caption": self.get_caption(),
            "font_size": self.font_size_var.get(),
            "line_spacing": self.line_spacing_var.get(),
            "text_weight": self.text_weight_var.get(),
            "letter_spacing": self.letter_spacing_var.get(),
            "font_family": self.font_family_var.get(),
            "font_file_path": self.font_file_path_var.get(),
            "text_align": self.text_align_var.get(),
            "text_vertical": self.text_vertical_var.get(),
            "text_x": self.text_x_var.get(),
            "text_y": self.text_y_var.get(),
            "text_color": self.text_color_var.get(),
            "text_custom_color": self.text_custom_color_var.get(),
            "text_stroke": self.text_stroke_var.get(),
            "text_shadow": self.text_shadow_var.get(),
            "plaque_enabled": self.plaque_enabled_var.get(),
            "plaque_position": self.plaque_position_var.get(),
            "style": self.style_var.get(),
            "plaque_png_enabled": self.plaque_png_enabled_var.get(),
            "plaque_png_path": self.plaque_png_path_var.get(),
            "plaque_x": self.plaque_x_var.get(),
            "plaque_y": self.plaque_y_var.get(),
            "plaque_width": self.plaque_width_var.get(),
            "plaque_height": self.plaque_height_var.get(),
            "plaque_opacity": self.plaque_opacity_var.get(),
            "plaque_radius": self.plaque_radius_var.get(),
            "plaque_border": self.plaque_border_var.get(),
            "plaque_pad_x": self.plaque_pad_x_var.get(),
            "plaque_pad_y": self.plaque_pad_y_var.get(),
            "watermark_enabled": self.watermark_enabled_var.get(),
            "watermark_path": self.watermark_path_var.get().strip(),
            "watermark_size": self.watermark_size_var.get(),
            "watermark_opacity": self.watermark_opacity_var.get(),
            "watermark_position": self.watermark_position_var.get(),
            "watermark_x": self.watermark_x_var.get(),
            "watermark_y": self.watermark_y_var.get(),
            "watermark_margin": self.watermark_margin_var.get(),
            "brightness": self.brightness_var.get(),
            "contrast": self.contrast_var.get(),
            "saturation": self.saturation_var.get(),
            "sharpness": self.sharpness_var.get(),
            "mirror": self.mirror_var.get(),
            "export_quality": self.export_quality_var.get(),
            "video_scale": self.video_scale_var.get(),
            "force_vertical_1080x1920": bool(self.config.get("force_vertical_1080x1920", FORCE_VERTICAL_OUTPUT)),
            "random_video": self.random_video_var.get(),
            "random_brightness": self.random_brightness_var.get(),
            "random_contrast": self.random_contrast_var.get(),
            "random_saturation": self.random_saturation_var.get(),
            "random_sharpness": self.random_sharpness_var.get(),
            "random_video_scale": self.random_video_scale_var.get(),
            "random_mirror": self.random_mirror_var.get(),
            "preview_fast": self.preview_fast_var.get(),
            "vk_safe_zones": self.vk_safe_zones_var.get(),
            "music_enabled": self.music_enabled_var.get(),
            "music_random": self.music_random_var.get(),
            "music_folder_path": self.music_folder_path_var.get(),
            "music_path": self.music_path_var.get().strip(),
            "music_track_choice": self.music_track_choice_var.get(),
            "original_volume": self.original_volume_var.get(),
            "music_volume": self.music_volume_var.get(),
            "ai_provider": self.ai_provider_var.get() if hasattr(self, "ai_provider_var") else "Gemini Free",
            "ai_api_key": self.ai_api_key_var.get() if hasattr(self, "ai_api_key_var") else "",
            "ai_model": self.ai_model_var.get() if hasattr(self, "ai_model_var") else AI_MODEL_DEFAULTS.get(self.ai_provider_var.get(), "gemini-2.0-flash") if hasattr(self, "ai_provider_var") else "gemini-2.0-flash",
            "ai_style": self.ai_style_var.get() if hasattr(self, "ai_style_var") else "Милые для VK",
            "ai_count": self.ai_count_var.get() if hasattr(self, "ai_count_var") else 10,
            "ai_prompt": self.get_ai_prompt_text() if hasattr(self, "ai_prompt_text") else self.config.get("ai_prompt", ""),
            "public_presets": getattr(self, "public_presets", {}),
            "current_video_public": self.video_public_var.get() if hasattr(self, "video_public_var") else "Хвостик",
            "current_photo_public": self.photo_public_var.get() if hasattr(self, "photo_public_var") else "Хвостик",
        }
        if randomize:
            self.apply_randomization(settings)
        return settings

    def apply_randomization(self, settings: dict) -> None:
        used = {
            "brightness": settings["brightness"],
            "contrast": settings["contrast"],
            "saturation": settings["saturation"],
            "sharpness": settings["sharpness"],
            "video_scale": settings.get("video_scale", 100),
            "mirror": settings["mirror"],
        }
        if settings.get("random_video"):
            settings["brightness"] = clamp(settings["brightness"] + random.randint(-settings["random_brightness"], settings["random_brightness"]), -80, 80)
            settings["contrast"] = clamp(settings["contrast"] + random.randint(-settings["random_contrast"], settings["random_contrast"]), 50, 170)
            settings["saturation"] = clamp(settings["saturation"] + random.randint(-settings["random_saturation"], settings["random_saturation"]), 0, 220)
            settings["sharpness"] = clamp(settings["sharpness"] + random.randint(-settings["random_sharpness"], settings["random_sharpness"]), 0, 100)
            settings["video_scale"] = clamp(settings.get("video_scale", 100) + random.randint(-settings.get("random_video_scale", 0), settings.get("random_video_scale", 0)), 100, 180)
            if settings.get("random_mirror"):
                settings["mirror"] = bool(random.getrandbits(1))
        used.update({
            "brightness_final": settings["brightness"],
            "contrast_final": settings["contrast"],
            "saturation_final": settings["saturation"],
            "sharpness_final": settings["sharpness"],
            "video_scale_final": settings.get("video_scale", 100),
            "mirror_final": settings["mirror"],
        })
        settings["random_used"] = used

    def move_selected_video_to_trash(self) -> None:
        if self.processing:
            messagebox.showinfo(APP_NAME, "Во время обработки переносить видео нельзя")
            return
        if not self.selected_video:
            messagebox.showinfo(APP_NAME, "Сначала выбери видео")
            return
        source = self.selected_video
        try:
            self.preview_playing = False
            if self.preview_after_id:
                try:
                    self.root.after_cancel(self.preview_after_id)
                except Exception:
                    pass
                self.preview_after_id = None
            self.close_preview_cap()
            PATHS["trash_videos"].mkdir(parents=True, exist_ok=True)
            target = unique_path(PATHS["trash_videos"] / source.name)
            shutil.move(str(source), str(target))
            self.log(f"Видео отправлено в хлам: {target.name}")
            self.selected_video = None
            self.current_frame_bgr = None
            self.video_label_var.set("Видео не выбрано")
            self.set_preview_seek(0, 0)
            self.load_first_video_from_folder(silent=True)
            self.update_preview()
        except Exception as exc:
            self.log(f"Не удалось отправить видео в хлам: {exc}")
            messagebox.showerror(APP_NAME, f"Не удалось отправить видео в хлам:\n{exc}")

    def process_video_clicked(self) -> None:
        if self.processing:
            messagebox.showinfo(APP_NAME, "Видео уже обрабатывается")
            return
        if not self.selected_video:
            self.load_first_video_from_folder(silent=True)
        if not self.selected_video:
            messagebox.showinfo(APP_NAME, "Положи видео в папку исходников или выбери его кнопкой")
            return

        self.worker_settings = self.collect_settings(randomize=True)
        self.worker_watermark_image = self.load_watermark_image(self.worker_settings)
        self.worker_plaque_image = self.load_plaque_image(self.worker_settings)
        self.progress_var.set(0)
        self.processing = True
        self.preview_playing = False
        self.close_preview_cap()
        thread = threading.Thread(target=self.process_video_worker, daemon=True)
        thread.start()

    def process_video_worker(self) -> None:
        source = self.selected_video
        try:
            self.safe_log(f"Старт обработки: {source.name}")
            self.safe_log(f"Паблик VK: {self.selected_public_name('video')}, папка: {self.public_output_folder('video')}")
            self.safe_status("Обработка видео...")

            random_used = self.worker_settings.get("random_used", {}) if self.worker_settings else {}
            if self.worker_settings and self.worker_settings.get("random_video"):
                self.safe_log(
                    "Рандом: "
                    f"ярк {random_used.get('brightness_final')}, "
                    f"контр {random_used.get('contrast_final')}%, "
                    f"нас {random_used.get('saturation_final')}%, "
                    f"резк {random_used.get('sharpness_final')}, "
                    f"масштаб {random_used.get('video_scale_final')}%, "
                    f"зеркало {yes_no(random_used.get('mirror_final'))}"
                )

            cap = cv2.VideoCapture(str(source))
            if not cap.isOpened():
                raise RuntimeError("Не удалось открыть видео")

            fps = cap.get(cv2.CAP_PROP_FPS) or 25
            width = int(cap.get(cv2.CAP_PROP_FRAME_WIDTH))
            height = int(cap.get(cv2.CAP_PROP_FRAME_HEIGHT))
            out_width, out_height = self.video_output_size(width, height, self.worker_settings)
            total = int(cap.get(cv2.CAP_PROP_FRAME_COUNT)) or 0
            self.safe_log(f"Формат выхода: {out_width}x{out_height}, масштаб {int(self.worker_settings.get('video_scale', 100))}%")

            output = self.next_public_output_file("video", ".mp4")
            output_dir = output.parent
            output_dir.mkdir(parents=True, exist_ok=True)
            temp = output.with_name(output.stem + "_temp_no_audio.mp4")

            fourcc = cv2.VideoWriter_fourcc(*"mp4v")
            writer = cv2.VideoWriter(str(temp), fourcc, fps, (out_width, out_height))
            if not writer.isOpened():
                cap.release()
                raise RuntimeError("Не удалось создать файл видео")

            frame_index = 0
            last_log = 0
            last_progress = -1
            while True:
                ok, frame = cap.read()
                if not ok:
                    break
                rendered = self.render_frame(frame, self.worker_settings, watermark_image=self.worker_watermark_image, plaque_image=self.worker_plaque_image)
                writer.write(rendered)
                frame_index += 1
                if total > 0:
                    percent = int(frame_index * 100 / total)
                    if percent != last_progress:
                        last_progress = percent
                        self.safe_progress(percent)
                    if percent >= last_log + 10:
                        last_log = percent
                        self.safe_log(f"Прогресс: {percent}%")
                        self.safe_status(f"Обработка видео: {percent}%")

            cap.release()
            writer.release()

            exported = self.export_with_ffmpeg(temp, source, output, self.worker_settings)
            if exported:
                try:
                    temp.unlink(missing_ok=True)
                except Exception:
                    pass
            else:
                if output.exists():
                    output.unlink(missing_ok=True)
                temp.rename(output)
                self.safe_log("ffmpeg не сработал, сохранено через встроенный кодек")

            self.safe_progress(100)
            self.move_source_if_safe(source)
            self.safe_log(f"Готово: {output}")
            self.safe_status("Готово")
            if not getattr(self, "video_batch_active", False):
                self.root.after(0, lambda: messagebox.showinfo(APP_NAME, f"Готовое видео сохранено:\n{output}"))
        except Exception as exc:
            err = str(exc)
            self.safe_log(f"Ошибка: {err}")
            self.safe_status("Ошибка обработки")
            self.root.after(0, lambda e=err: messagebox.showerror(APP_NAME, f"Ошибка обработки:\n{e}"))
        finally:
            self.processing = False
            self.worker_watermark_image = None
            self.worker_plaque_image = None
            self.root.after(0, self.after_processing_refresh)

    def after_processing_refresh(self) -> None:
        if getattr(self, "video_batch_queue", None):
            self.selected_video = None
            self.current_frame_bgr = None
            self.video_label_var.set("Видео не выбрано")
            self.root.after(250, self.process_next_video_in_batch)
            return
        self.selected_video = None
        self.current_frame_bgr = None
        self.video_label_var.set("Видео не выбрано")
        self.load_first_video_from_folder(silent=True)
        self.update_preview()

    def export_with_ffmpeg(self, temp_video: Path, source_video: Path, output_video: Path, settings: dict | None) -> bool:
        if imageio_ffmpeg is None:
            self.safe_log("ffmpeg недоступен")
            return False
        try:
            ffmpeg = imageio_ffmpeg.get_ffmpeg_exe()
            quality = int((settings or {}).get("export_quality", 85))
            crf = int(round(35 - (quality - 45) * (17 / 55)))
            crf = clamp(crf, 18, 35)
            has_original_audio = self.video_has_audio(ffmpeg, source_video)
            original_volume = clamp(int((settings or {}).get("original_volume", 100)), 0, 200) / 100.0
            music_volume = clamp(int((settings or {}).get("music_volume", 55)), 0, 200) / 100.0
            music_track = self.resolve_music_track(settings)

            base = [
                ffmpeg,
                "-y",
                "-i",
                str(temp_video),
                "-i",
                str(source_video),
            ]
            if music_track is not None:
                base.extend(["-stream_loop", "-1", "-i", str(music_track)])

            common_video = [
                "-map",
                "0:v:0",
                "-c:v",
                "libx264",
                "-preset",
                "veryfast",
                "-crf",
                str(crf),
                "-pix_fmt",
                "yuv420p",
            ]

            audio_filter = None
            audio_map = []
            audio_note = "без звука"

            if music_track is not None and music_volume > 0:
                if has_original_audio and original_volume > 0:
                    audio_filter = f"[1:a]volume={original_volume:.2f}[a0];[2:a]volume={music_volume:.2f}[a1];[a0][a1]amix=inputs=2:duration=longest:dropout_transition=2[aout]"
                    audio_note = f"оригинал {int(original_volume * 100)}%, музыка {int(music_volume * 100)}%, трек {music_track.name}"
                else:
                    audio_filter = f"[2:a]volume={music_volume:.2f}[aout]"
                    audio_note = f"музыка {int(music_volume * 100)}%, трек {music_track.name}"
            elif has_original_audio and original_volume > 0:
                if abs(original_volume - 1.0) < 0.001:
                    audio_map = ["-map", "1:a?", "-c:a", "aac"]
                    audio_note = "оригинальный звук 100%"
                else:
                    audio_filter = f"[1:a]volume={original_volume:.2f}[aout]"
                    audio_note = f"оригинальный звук {int(original_volume * 100)}%"

            if audio_filter:
                cmd = base + ["-filter_complex", audio_filter] + common_video + ["-map", "[aout]", "-c:a", "aac", "-shortest", str(output_video)]
            else:
                cmd = base + common_video + audio_map + ["-shortest", str(output_video)]

            result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            if result.returncode == 0 and output_video.exists() and output_video.stat().st_size > 0:
                self.safe_log(f"Экспорт с качеством {quality}, звук: {audio_note}")
                return True
            self.safe_log("ffmpeg не смог экспортировать финальное видео")
            if result.stderr:
                self.safe_log(result.stderr[-600:])
            return False
        except Exception as exc:
            self.safe_log(f"ffmpeg ошибка: {exc}")
            return False

    def video_has_audio(self, ffmpeg: str, source_video: Path) -> bool:
        try:
            result = subprocess.run([ffmpeg, "-i", str(source_video)], stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
            return "Audio:" in (result.stderr or "")
        except Exception:
            return False

    def move_source_if_safe(self, source: Path) -> None:
        try:
            source_resolved = source.resolve()
            source_dir = PATHS["source_videos"].resolve()
            if source_resolved.parent != source_dir:
                self.safe_log("Источник выбран вне папки source_videos, файл не перенесен")
                return
            target = unique_path(PATHS["used_videos"] / source.name)
            shutil.move(str(source), str(target))
            self.safe_log(f"Исходник перенесен: {target.name}")
        except Exception as exc:
            self.safe_log(f"Не удалось перенести исходник: {exc}")


    def video_output_size(self, source_width: int, source_height: int, settings: dict | None = None) -> tuple[int, int]:
        """Размер финального кадра. По умолчанию скрыто принудительно 1080x1920 для Reels/Shorts."""
        settings = settings or {}
        if bool(settings.get("force_vertical_1080x1920", FORCE_VERTICAL_OUTPUT)):
            return VERTICAL_OUTPUT_SIZE
        return max(2, int(source_width)), max(2, int(source_height))

    def fit_video_to_output(self, frame_bgr: np.ndarray, settings: dict | None = None) -> np.ndarray:
        """Подгоняет кадр под выход без черных полос и применяет масштаб видео.

        Масштаб 100% = обычный cover под 1080x1920. Больше 100% = дополнительное приближение.
        """
        settings = settings or {}
        src_h, src_w = frame_bgr.shape[:2]
        if src_w <= 0 or src_h <= 0:
            return frame_bgr

        force_vertical = bool(settings.get("force_vertical_1080x1920", FORCE_VERTICAL_OUTPUT))
        target_w = int(settings.get("output_width", 0) or (VERTICAL_OUTPUT_SIZE[0] if force_vertical else src_w))
        target_h = int(settings.get("output_height", 0) or (VERTICAL_OUTPUT_SIZE[1] if force_vertical else src_h))
        target_w = max(2, target_w)
        target_h = max(2, target_h)

        scale_pct = clamp(int(settings.get("video_scale", 100)), 100, 180)
        extra_zoom = scale_pct / 100.0

        if force_vertical or target_w != src_w or target_h != src_h:
            base_scale = max(target_w / max(1, src_w), target_h / max(1, src_h))
            resize_scale = base_scale * extra_zoom
            resized_w = max(target_w, int(np.ceil(src_w * resize_scale)))
            resized_h = max(target_h, int(np.ceil(src_h * resize_scale)))
        else:
            if scale_pct <= 100:
                return frame_bgr
            resized_w = max(2, int(np.ceil(src_w * extra_zoom)))
            resized_h = max(2, int(np.ceil(src_h * extra_zoom)))

        interpolation = cv2.INTER_AREA if resized_w < src_w or resized_h < src_h else cv2.INTER_LINEAR
        resized = cv2.resize(frame_bgr, (resized_w, resized_h), interpolation=interpolation)
        x = max(0, (resized_w - target_w) // 2)
        y = max(0, (resized_h - target_h) // 2)
        cropped = resized[y:y + target_h, x:x + target_w]
        if cropped.shape[1] != target_w or cropped.shape[0] != target_h:
            cropped = cv2.resize(cropped, (target_w, target_h), interpolation=cv2.INTER_LINEAR)
        return cropped

    def render_frame(self, frame_bgr: np.ndarray, settings: dict | None = None, watermark_image: Image.Image | None = None, plaque_image: Image.Image | None = None) -> np.ndarray:
        if settings is None:
            settings = self.collect_settings(randomize=False) if hasattr(self, "caption_text") else {}
        fitted = self.fit_video_to_output(frame_bgr, settings)
        adjusted = self.apply_video_filters(fitted, settings)
        rgb = cv2.cvtColor(adjusted, cv2.COLOR_BGR2RGB)
        image = Image.fromarray(rgb).convert("RGBA")
        image = self.draw_caption_plaque(image, settings, plaque_image)
        image = self.draw_watermark(image, settings, watermark_image)
        return cv2.cvtColor(np.array(image.convert("RGB")), cv2.COLOR_RGB2BGR)

    def apply_video_filters(self, frame_bgr: np.ndarray, settings: dict) -> np.ndarray:
        frame = frame_bgr.copy()
        if settings.get("mirror"):
            frame = cv2.flip(frame, 1)

        contrast = float(settings.get("contrast", 100)) / 100.0
        brightness = int(settings.get("brightness", 0))
        if abs(contrast - 1.0) > 0.001 or brightness != 0:
            frame = cv2.convertScaleAbs(frame, alpha=contrast, beta=brightness)

        saturation = int(settings.get("saturation", 100))
        if saturation != 100:
            hsv = cv2.cvtColor(frame, cv2.COLOR_BGR2HSV).astype(np.float32)
            hsv[:, :, 1] = np.clip(hsv[:, :, 1] * (saturation / 100.0), 0, 255)
            frame = cv2.cvtColor(hsv.astype(np.uint8), cv2.COLOR_HSV2BGR)

        sharpness = int(settings.get("sharpness", 0))
        if sharpness > 0:
            amount = sharpness / 100.0
            blurred = cv2.GaussianBlur(frame, (0, 0), 1.2)
            frame = cv2.addWeighted(frame, 1.0 + amount, blurred, -amount, 0)

        return frame

    def draw_caption_plaque(self, image: Image.Image, settings: dict | None = None, plaque_image: Image.Image | None = None) -> Image.Image:
        if settings is None:
            settings = self.collect_settings(randomize=False) if hasattr(self, "caption_text") else {}
        text = str(settings.get("caption", "") or "").strip()
        if not text:
            return image
        w, h = image.size
        plaque_enabled = bool(settings.get("plaque_enabled", True))

        plaque_w = int(w * int(settings.get("plaque_width", 72)) / 100)
        plaque_h = int(h * int(settings.get("plaque_height", 18)) / 100)
        plaque_w = clamp(plaque_w, int(w * 0.25), w)
        plaque_h = clamp(plaque_h, max(60, int(h * 0.08)), int(h * 0.5))

        center_x = int(w * clamp(int(settings.get("plaque_x", 50)), 0, 100) / 100)
        center_y = int(h * clamp(int(settings.get("plaque_y", 82)), 0, 100) / 100)
        x = clamp(center_x - plaque_w // 2, 0, max(0, w - plaque_w))
        y = clamp(center_y - plaque_h // 2, 0, max(0, h - plaque_h))

        style = STYLE_DATA.get(settings.get("style", "Кремовая"), STYLE_DATA["Кремовая"])
        overlay = Image.new("RGBA", image.size, (0, 0, 0, 0))
        draw = ImageDraw.Draw(overlay)

        opacity = clamp(int(settings.get("plaque_opacity", 92)), 0, 100)
        fill = apply_alpha(style["fill"], opacity)
        outline = apply_alpha(style["outline"], opacity)
        radius_pct = int(settings.get("plaque_radius", 26))
        radius = int(min(plaque_w, plaque_h) * radius_pct / 100)
        outline_width = int(settings.get("plaque_border", 4)) if plaque_enabled else 0

        if plaque_enabled:
            if settings.get("plaque_png_enabled") and plaque_image is not None:
                png = plaque_image.copy().convert("RGBA")
                png = png.resize((plaque_w, plaque_h), Image.Resampling.LANCZOS)
                if opacity < 100:
                    alpha = png.getchannel("A")
                    alpha = alpha.point(lambda p: int(p * opacity / 100))
                    png.putalpha(alpha)
                overlay.alpha_composite(png, (x, y))
            else:
                draw.rounded_rectangle(
                    [x, y, x + plaque_w, y + plaque_h],
                    radius=radius,
                    fill=fill,
                    outline=outline if outline_width > 0 else None,
                    width=max(1, outline_width),
                )

        pad_x = int(plaque_w * int(settings.get("plaque_pad_x", 8)) / 100)
        pad_y = int(plaque_h * int(settings.get("plaque_pad_y", 16)) / 100)
        area_w = max(10, plaque_w - pad_x * 2)
        area_h = max(10, plaque_h - pad_y * 2)
        target_font_size = int(settings.get("font_size", 46))
        line_spacing = int(settings.get("line_spacing", 10))
        letter_spacing = int(settings.get("letter_spacing", 0))
        stroke_width = int(settings.get("text_stroke", 0))
        text_weight = int(settings.get("text_weight", 0))
        effective_weight = effective_text_weight(text_weight)
        measure_stroke = stroke_width + effective_weight

        font, lines, total_h = self.fit_text(
            draw,
            text,
            target_font_size,
            area_w,
            area_h,
            line_spacing,
            measure_stroke,
            letter_spacing,
            settings.get("font_family", "Segoe UI"),
            settings.get("font_file_path", ""),
        )
        text_fill = resolve_text_color(settings, style)
        stroke_fill = best_stroke_color(text_fill)
        align = settings.get("text_align", "По центру")
        vertical = settings.get("text_vertical", "По центру")
        text_x_pct = clamp(int(settings.get("text_x", 50)), 0, 100)
        text_y_pct = clamp(int(settings.get("text_y", 50)), 0, 100)
        shadow = bool(settings.get("text_shadow", False))

        area_left = x + pad_x
        area_top = y + pad_y
        free_h = max(0, area_h - total_h)
        if vertical == "Сверху":
            text_y = area_top
        elif vertical == "Снизу":
            text_y = area_top + free_h
        elif vertical == "Вручную":
            # В ручном режиме X/Y работают как положение центра блока текста внутри области плашки.
            # Так движение заметно и на PNG плашках, но текст все равно не вылезает за область.
            desired_center_y = area_top + int(area_h * text_y_pct / 100)
            text_y = clamp(desired_center_y - total_h // 2, area_top, area_top + free_h)
        else:
            text_y = area_top + free_h // 2

        for line in lines:
            line_w = text_width(draw, line, font, measure_stroke, letter_spacing)
            line_h = text_height(draw, line, font, measure_stroke)
            free_w = max(0, area_w - line_w)
            if align == "Слева":
                text_x = area_left
            elif align == "Справа":
                text_x = area_left + free_w
            elif align == "Вручную":
                desired_center_x = area_left + int(area_w * text_x_pct / 100)
                text_x = clamp(desired_center_x - line_w // 2, area_left, area_left + free_w)
            else:
                text_x = area_left + free_w // 2

            if shadow:
                shadow_offset = max(2, target_font_size // 18)
                draw_weighted_text(
                    draw,
                    (text_x + shadow_offset, text_y + shadow_offset),
                    line,
                    font,
                    (0, 0, 0, 120),
                    stroke_width,
                    (0, 0, 0, 100),
                    text_weight,
                )
            draw_weighted_text(
                draw,
                (text_x, text_y),
                line,
                font,
                text_fill,
                stroke_width,
                stroke_fill,
                text_weight,
                letter_spacing,
            )
            text_y += line_h + line_spacing

        return Image.alpha_composite(image, overlay)

    def fit_text(self, draw: ImageDraw.ImageDraw, text: str, font_size: int, max_w: int, max_h: int, line_spacing: int, stroke_width: int = 0, letter_spacing: int = 0, font_family: str = "Segoe UI", font_file_path: str = ""):
        size = max(12, font_size)
        while size >= 12:
            font = load_font(size, font_family, font_file_path)
            lines = wrap_text(draw, text, font, max_w, stroke_width, letter_spacing)
            total_h = text_block_height(draw, lines, font, line_spacing, stroke_width)
            widest = max((text_width(draw, line, font, stroke_width, letter_spacing) for line in lines), default=0)
            if total_h <= max_h and widest <= max_w:
                return font, lines, total_h
            size -= 2

        font = load_font(12, font_family, font_file_path)
        lines = wrap_text(draw, text, font, max_w, stroke_width, letter_spacing)
        while len(lines) > 1 and text_block_height(draw, lines, font, line_spacing, stroke_width) > max_h:
            lines = lines[:-1]
            if lines:
                lines[-1] = trim_line(draw, lines[-1] + "...", font, max_w, stroke_width, letter_spacing)
        total_h = text_block_height(draw, lines, font, line_spacing, stroke_width)
        return font, lines, total_h


    def load_plaque_image(self, settings: dict | None = None) -> Image.Image | None:
        if settings is None:
            settings = self.collect_settings(randomize=False)
        if not settings.get("plaque_png_enabled"):
            return None
        path_text = str(settings.get("plaque_png_path", "")).strip()
        if not path_text:
            return None
        path = Path(path_text)
        if not path.exists():
            return None
        try:
            if self.plaque_cache_path == path and self.plaque_cache_image is not None:
                return self.plaque_cache_image
            img = Image.open(path).convert("RGBA")
            self.plaque_cache_path = path
            self.plaque_cache_image = img
            return img
        except Exception as exc:
            self.log(f"Ошибка PNG плашки: {exc}") if hasattr(self, "log_text") else None
            return None

    def load_watermark_image(self, settings: dict | None = None) -> Image.Image | None:
        if settings is None:
            settings = self.collect_settings(randomize=False)
        if not settings.get("watermark_enabled"):
            return None
        path_text = str(settings.get("watermark_path", "")).strip()
        if not path_text:
            return None
        path = Path(path_text)
        if not path.exists():
            return None
        try:
            if self.watermark_cache_path == path and self.watermark_cache_image is not None:
                return self.watermark_cache_image
            img = Image.open(path).convert("RGBA")
            self.watermark_cache_path = path
            self.watermark_cache_image = img
            return img
        except Exception as exc:
            self.log(f"Ошибка watermark: {exc}") if hasattr(self, "log_text") else None
            return None

    def draw_watermark(self, image: Image.Image, settings: dict, watermark_image: Image.Image | None) -> Image.Image:
        if watermark_image is None or not settings.get("watermark_enabled"):
            return image
        w, h = image.size
        wm = watermark_image.copy().convert("RGBA")
        size_pct = clamp(int(settings.get("watermark_size", 16)), 1, 100)
        target_w = max(8, int(w * size_pct / 100))
        ratio = target_w / max(1, wm.width)
        target_h = max(8, int(wm.height * ratio))
        if target_h > int(h * 0.8):
            target_h = int(h * 0.8)
            target_w = max(8, int(wm.width * (target_h / max(1, wm.height))))
        wm = wm.resize((target_w, target_h), Image.Resampling.LANCZOS)

        opacity = clamp(int(settings.get("watermark_opacity", 75)), 0, 100)
        if opacity < 100:
            alpha = wm.getchannel("A")
            alpha = alpha.point(lambda p: int(p * opacity / 100))
            wm.putalpha(alpha)

        margin = int(min(w, h) * clamp(int(settings.get("watermark_margin", 4)), 0, 20) / 100)
        pos = settings.get("watermark_position", "Снизу справа")
        if pos == "Сверху слева":
            x, y = margin, margin
        elif pos == "Сверху справа":
            x, y = w - target_w - margin, margin
        elif pos == "Снизу слева":
            x, y = margin, h - target_h - margin
        elif pos == "По центру":
            x, y = (w - target_w) // 2, (h - target_h) // 2
        elif pos == "Вручную":
            center_x = int(w * clamp(int(settings.get("watermark_x", 88)), 0, 100) / 100)
            center_y = int(h * clamp(int(settings.get("watermark_y", 88)), 0, 100) / 100)
            x, y = center_x - target_w // 2, center_y - target_h // 2
        else:
            x, y = w - target_w - margin, h - target_h - margin
        x = clamp(x, 0, max(0, w - target_w))
        y = clamp(y, 0, max(0, h - target_h))

        overlay = Image.new("RGBA", image.size, (0, 0, 0, 0))
        overlay.alpha_composite(wm, (x, y))
        return Image.alpha_composite(image, overlay)

    def collect_photo_config_values(self) -> dict:
        data = {
            "photo_caption": self.get_photo_caption() if hasattr(self, "photo_caption_text") else self.config.get("photo_caption", ""),
            "photo_export_quality": self.photo_export_quality_var.get(),
            "photo_font_size": self.photo_font_size_var.get(),
            "photo_line_spacing": self.photo_line_spacing_var.get(),
            "photo_text_weight": self.photo_text_weight_var.get(),
            "photo_letter_spacing": self.photo_letter_spacing_var.get(),
            "photo_font_family": self.photo_font_family_var.get(),
            "photo_font_file_path": self.photo_font_file_path_var.get(),
            "photo_text_align": self.photo_text_align_var.get(),
            "photo_text_vertical": self.photo_text_vertical_var.get(),
            "photo_text_x": self.photo_text_x_var.get(),
            "photo_text_y": self.photo_text_y_var.get(),
            "photo_text_color": self.photo_text_color_var.get(),
            "photo_text_custom_color": self.photo_text_custom_color_var.get(),
            "photo_text_stroke": self.photo_text_stroke_var.get(),
            "photo_text_shadow": self.photo_text_shadow_var.get(),
            "photo_plaque_enabled": self.photo_plaque_enabled_var.get(),
            "photo_plaque_position": self.photo_plaque_position_var.get(),
            "photo_style": self.photo_style_var.get(),
            "photo_plaque_png_enabled": self.photo_plaque_png_enabled_var.get(),
            "photo_plaque_png_path": self.photo_plaque_png_path_var.get(),
            "photo_plaque_x": self.photo_plaque_x_var.get(),
            "photo_plaque_y": self.photo_plaque_y_var.get(),
            "photo_plaque_width": self.photo_plaque_width_var.get(),
            "photo_plaque_height": self.photo_plaque_height_var.get(),
            "photo_plaque_opacity": self.photo_plaque_opacity_var.get(),
            "photo_plaque_radius": self.photo_plaque_radius_var.get(),
            "photo_plaque_border": self.photo_plaque_border_var.get(),
            "photo_plaque_pad_x": self.photo_plaque_pad_x_var.get(),
            "photo_plaque_pad_y": self.photo_plaque_pad_y_var.get(),
            "photo_watermark_enabled": self.photo_watermark_enabled_var.get(),
            "photo_watermark_path": self.photo_watermark_path_var.get(),
            "photo_watermark_size": self.photo_watermark_size_var.get(),
            "photo_watermark_opacity": self.photo_watermark_opacity_var.get(),
            "photo_watermark_position": self.photo_watermark_position_var.get(),
            "photo_watermark_x": self.photo_watermark_x_var.get(),
            "photo_watermark_y": self.photo_watermark_y_var.get(),
            "photo_watermark_margin": self.photo_watermark_margin_var.get(),
            "photo_random_enabled": self.photo_random_enabled_var.get(),
        }
        for key in PHOTO_FILTER_SPECS:
            data[f"photo_{key}"] = self.photo_filter_vars[key].get()
            data[f"photo_random_{key}"] = self.photo_random_range_vars[key].get()
        return data

    def get_photo_caption(self) -> str:
        if not hasattr(self, "photo_caption_text"):
            return ""
        return self.photo_caption_text.get("1.0", "end").strip()

    def on_photo_font_family_changed(self) -> None:
        self.photo_font_file_path_var.set("")
        self.refresh_photo_font_label()
        self.on_settings_changed()

    def choose_photo_font_file(self) -> None:
        path = filedialog.askopenfilename(
            title="Выбрать шрифт для фото",
            initialdir=str(PATHS["fonts"]),
            filetypes=[("Файлы шрифтов", "*.ttf *.otf *.ttc"), ("Все файлы", "*.*")],
        )
        if not path:
            return
        chosen = Path(path)
        if chosen.suffix.lower() not in FONT_EXTS:
            messagebox.showwarning(APP_NAME, "Лучше выбрать TTF, OTF или TTC")
            return
        self.photo_font_file_path_var.set(str(chosen))
        self.refresh_photo_font_label()
        self.refresh_photo_font_combo()
        self.on_settings_changed()
        self.photo_log(f"Выбран файл шрифта для фото: {chosen.name}")

    def clear_photo_font_file(self) -> None:
        self.photo_font_file_path_var.set("")
        self.refresh_photo_font_label()
        self.on_settings_changed()
        self.photo_log("Файл шрифта фото очищен")

    def refresh_photo_font_label(self) -> None:
        if not hasattr(self, "photo_font_file_path_var"):
            return
        path_text = self.photo_font_file_path_var.get().strip()
        if path_text:
            self.photo_font_label_var.set(f"Файл шрифта: {Path(path_text).name}")
        else:
            self.photo_font_label_var.set(f"Шрифт из списка: {self.photo_font_family_var.get()}")

    def refresh_photo_font_combo(self) -> None:
        if hasattr(self, "photo_font_combo"):
            self.photo_font_combo.configure(values=available_font_choices())

    def choose_photo_text_color(self) -> None:
        current = parse_color_code(self.photo_text_custom_color_var.get())
        initial = "#FFFFFF"
        if current is not None:
            initial = "#%02X%02X%02X" % current[:3]
        _rgb, hex_code = colorchooser.askcolor(color=initial, title="Выбрать цвет текста фото")
        if not hex_code:
            return
        self.photo_text_custom_color_var.set(hex_code.upper())
        self.photo_text_color_var.set("Свой код")
        self.on_settings_changed()
        self.photo_log(f"Цвет текста фото: {hex_code.upper()}")

    def on_photo_plaque_position_changed(self) -> None:
        position = self.photo_plaque_position_var.get()
        if position == "Сверху":
            self.photo_plaque_y_var.set(18)
        elif position == "По центру":
            self.photo_plaque_y_var.set(50)
        elif position == "Снизу":
            self.photo_plaque_y_var.set(82)
        self.on_settings_changed()

