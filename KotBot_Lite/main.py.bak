        self.photo_text_align_var = tk.StringVar(value=self.config.get("photo_text_align", "По центру"))
        if self.photo_text_align_var.get() not in TEXT_ALIGNMENTS:
            self.photo_text_align_var.set("По центру")
        self.photo_text_vertical_var = tk.StringVar(value=self.config.get("photo_text_vertical", "По центру"))
        if self.photo_text_vertical_var.get() not in TEXT_VERTICALS:
            self.photo_text_vertical_var.set("По центру")
        self.photo_text_x_var = tk.IntVar(value=int(self.config.get("photo_text_x", 50)))
        self.photo_text_y_var = tk.IntVar(value=int(self.config.get("photo_text_y", 50)))
        self.photo_text_color_var = tk.StringVar(value=self.config.get("photo_text_color", "Авто"))
        if self.photo_text_color_var.get() not in TEXT_COLOR_DATA:
            self.photo_text_color_var.set("Авто")
        self.photo_text_custom_color_var = tk.StringVar(value=self.config.get("photo_text_custom_color", "#FFFFFF"))
        self.photo_text_stroke_var = tk.IntVar(value=int(self.config.get("photo_text_stroke", 0)))
        self.photo_text_shadow_var = tk.BooleanVar(value=bool(self.config.get("photo_text_shadow", False)))

        self.photo_plaque_enabled_var = tk.BooleanVar(value=bool(self.config.get("photo_plaque_enabled", True)))
        self.photo_plaque_position_var = tk.StringVar(value=self.config.get("photo_plaque_position", "Снизу"))
        if self.photo_plaque_position_var.get() not in PLAQUE_POSITIONS:
            self.photo_plaque_position_var.set("Снизу")
        self.photo_style_var = tk.StringVar(value=self.config.get("photo_style", "Кремовая"))
        if self.photo_style_var.get() not in STYLE_DATA:
            self.photo_style_var.set("Кремовая")
        self.photo_plaque_png_enabled_var = tk.BooleanVar(value=bool(self.config.get("photo_plaque_png_enabled", False)))
        self.photo_plaque_png_path_var = tk.StringVar(value=self.config.get("photo_plaque_png_path", ""))
        self.photo_plaque_png_label_var = tk.StringVar(value="PNG плашка фото не выбрана")
        self.photo_plaque_x_var = tk.IntVar(value=int(self.config.get("photo_plaque_x", 50)))
        self.photo_plaque_y_var = tk.IntVar(value=int(self.config.get("photo_plaque_y", 82)))
        self.photo_plaque_width_var = tk.IntVar(value=int(self.config.get("photo_plaque_width", 72)))
        self.photo_plaque_height_var = tk.IntVar(value=int(self.config.get("photo_plaque_height", 18)))
        self.photo_plaque_opacity_var = tk.IntVar(value=int(self.config.get("photo_plaque_opacity", 92)))
        self.photo_plaque_radius_var = tk.IntVar(value=int(self.config.get("photo_plaque_radius", 26)))
        self.photo_plaque_border_var = tk.IntVar(value=int(self.config.get("photo_plaque_border", 4)))
        self.photo_plaque_pad_x_var = tk.IntVar(value=int(self.config.get("photo_plaque_pad_x", 8)))
        self.photo_plaque_pad_y_var = tk.IntVar(value=int(self.config.get("photo_plaque_pad_y", 16)))

        self.photo_watermark_enabled_var = tk.BooleanVar(value=bool(self.config.get("photo_watermark_enabled", False)))
        self.photo_watermark_path_var = tk.StringVar(value=self.config.get("photo_watermark_path", ""))
        self.photo_watermark_size_var = tk.IntVar(value=int(self.config.get("photo_watermark_size", 16)))
        self.photo_watermark_opacity_var = tk.IntVar(value=int(self.config.get("photo_watermark_opacity", 75)))
        self.photo_watermark_position_var = tk.StringVar(value=self.config.get("photo_watermark_position", "Снизу справа"))
        if self.photo_watermark_position_var.get() not in WATERMARK_POSITIONS:
            self.photo_watermark_position_var.set("Снизу справа")
        self.photo_watermark_x_var = tk.IntVar(value=int(self.config.get("photo_watermark_x", 88)))
        self.photo_watermark_y_var = tk.IntVar(value=int(self.config.get("photo_watermark_y", 88)))
        self.photo_watermark_margin_var = tk.IntVar(value=int(self.config.get("photo_watermark_margin", 4)))
        self.photo_watermark_label_var = tk.StringVar(value="Watermark фото не выбран")

        self.photo_filter_vars = {}
        self.photo_random_range_vars = {}
        for key, (_label, _min_v, _max_v, default, random_default) in PHOTO_FILTER_SPECS.items():
            self.photo_filter_vars[key] = tk.IntVar(value=int(self.config.get(f"photo_{key}", default)))
            self.photo_random_range_vars[key] = tk.IntVar(value=int(self.config.get(f"photo_random_{key}", random_default)))
        self.photo_random_enabled_var = tk.BooleanVar(value=bool(self.config.get("photo_random_enabled", False)))

        presets = self.config.get("public_presets", {})
        if not isinstance(presets, dict) or not presets:
            presets = {
                "Хвостик": {"video": {}, "photo": {}},
                "Клевер": {"video": {}, "photo": {}},
                "Паблик 3": {"video": {}, "photo": {}},
            }
        normalized = {}
        for name, value in presets.items():
            clean_name = str(name).strip()
            if not clean_name:
                continue
            if not isinstance(value, dict):
                value = {}
            normalized[clean_name] = {
                "video": value.get("video", {}) if isinstance(value.get("video", {}), dict) else {},
                "photo": value.get("photo", {}) if isinstance(value.get("photo", {}), dict) else {},
            }
        if not normalized:
            normalized = {"Хвостик": {"video": {}, "photo": {}}}
        self.public_presets = normalized
        first_public = next(iter(self.public_presets.keys()))
        self.video_public_var = tk.StringVar(value=self.config.get("current_video_public", first_public))
        if self.video_public_var.get() not in self.public_presets:
            self.video_public_var.set(first_public)
        self.photo_public_var = tk.StringVar(value=self.config.get("current_photo_public", first_public))
        if self.photo_public_var.get() not in self.public_presets:
            self.photo_public_var.set(first_public)

    def load_config(self) -> dict:
        if CONFIG_PATH.exists():
            try:
                return json.loads(CONFIG_PATH.read_text(encoding="utf-8"))
            except Exception:
                return {}
        return {}

    def save_config(self) -> None:
        caption = self.get_caption() if hasattr(self, "caption_text") else self.config.get("caption", "")
        data = {
            "caption": caption,
            "font_size": self.font_size_var.get(),
            "line_spacing": self.line_spacing_var.get(),
            "text_weight": self.text_weight_var.get(),
            "letter_spacing": self.letter_spacing_var.get(),
            "font_family": self.font_family_var.get(),
            "font_file_path": self.font_file_path_var.get(),
            "text_align": self.text_align_var.get(),
            "text_vertical": self.text_vertical_var.get(),
            "text_x": self.text_x_var.get(),
            "text_y": self.text_y_var.get(),
            "text_color": self.text_color_var.get(),
            "text_custom_color": self.text_custom_color_var.get(),
            "text_stroke": self.text_stroke_var.get(),
            "text_shadow": self.text_shadow_var.get(),
            "plaque_enabled": self.plaque_enabled_var.get(),
            "plaque_position": self.plaque_position_var.get(),
            "style": self.style_var.get(),
            "plaque_png_enabled": self.plaque_png_enabled_var.get(),
            "plaque_png_path": self.plaque_png_path_var.get(),
            "plaque_x": self.plaque_x_var.get(),
            "plaque_y": self.plaque_y_var.get(),
            "plaque_width": self.plaque_width_var.get(),
            "plaque_height": self.plaque_height_var.get(),
            "plaque_opacity": self.plaque_opacity_var.get(),
            "plaque_radius": self.plaque_radius_var.get(),
            "plaque_border": self.plaque_border_var.get(),
            "plaque_pad_x": self.plaque_pad_x_var.get(),
            "plaque_pad_y": self.plaque_pad_y_var.get(),
            "watermark_enabled": self.watermark_enabled_var.get(),
            "watermark_path": self.watermark_path_var.get(),
            "watermark_size": self.watermark_size_var.get(),
            "watermark_opacity": self.watermark_opacity_var.get(),
            "watermark_position": self.watermark_position_var.get(),
            "watermark_x": self.watermark_x_var.get(),
            "watermark_y": self.watermark_y_var.get(),
            "watermark_margin": self.watermark_margin_var.get(),
            "brightness": self.brightness_var.get(),
            "contrast": self.contrast_var.get(),
            "saturation": self.saturation_var.get(),
            "sharpness": self.sharpness_var.get(),
            "mirror": self.mirror_var.get(),
            "export_quality": self.export_quality_var.get(),
            "video_scale": self.video_scale_var.get(),
            "force_vertical_1080x1920": bool(self.config.get("force_vertical_1080x1920", FORCE_VERTICAL_OUTPUT)),
            "random_video": self.random_video_var.get(),
            "random_brightness": self.random_brightness_var.get(),
            "random_contrast": self.random_contrast_var.get(),
            "random_saturation": self.random_saturation_var.get(),
            "random_sharpness": self.random_sharpness_var.get(),
            "random_video_scale": self.random_video_scale_var.get(),
            "random_mirror": self.random_mirror_var.get(),
            "preview_fast": self.preview_fast_var.get(),
            "vk_safe_zones": self.vk_safe_zones_var.get(),
            "music_enabled": self.music_enabled_var.get(),
            "music_random": self.music_random_var.get(),
            "music_folder_path": self.music_folder_path_var.get(),
            "music_path": self.music_path_var.get(),
            "music_track_choice": self.music_track_choice_var.get(),
            "original_volume": self.original_volume_var.get(),
            "music_volume": self.music_volume_var.get(),
            "ai_provider": self.ai_provider_var.get() if hasattr(self, "ai_provider_var") else "Gemini Free",
            "ai_api_key": self.ai_api_key_var.get() if hasattr(self, "ai_api_key_var") else "",
            "ai_model": self.ai_model_var.get() if hasattr(self, "ai_model_var") else AI_MODEL_DEFAULTS.get(self.ai_provider_var.get(), "gemini-2.0-flash") if hasattr(self, "ai_provider_var") else "gemini-2.0-flash",
            "ai_style": self.ai_style_var.get() if hasattr(self, "ai_style_var") else "Милые для VK",
            "ai_count": self.ai_count_var.get() if hasattr(self, "ai_count_var") else 10,
            "ai_prompt": self.get_ai_prompt_text() if hasattr(self, "ai_prompt_text") else self.config.get("ai_prompt", ""),
            "public_presets": getattr(self, "public_presets", {}),
            "current_video_public": self.video_public_var.get() if hasattr(self, "video_public_var") else "Хвостик",
            "current_photo_public": self.photo_public_var.get() if hasattr(self, "photo_public_var") else "Хвостик",
        }
        data.update(self.collect_photo_config_values() if hasattr(self, "photo_filter_vars") else {})
        try:
            CONFIG_PATH.write_text(json.dumps(data, ensure_ascii=False, indent=2), encoding="utf-8")
        except Exception:
            pass

    def build_ui(self) -> None:
        self.root.configure(bg="#f4f1ea")

        self.main_notebook = ttk.Notebook(self.root)
        self.main_notebook.pack(fill="both", expand=True, padx=8, pady=8)

        video_page = tk.Frame(self.main_notebook, bg="#f4f1ea")
        photo_page = tk.Frame(self.main_notebook, bg="#f4f1ea")
        folders_page = tk.Frame(self.main_notebook, bg="#f4f1ea")
        self.main_notebook.add(video_page, text="Видео")
        self.main_notebook.add(photo_page, text="Фото")
        self.main_notebook.add(folders_page, text="Папки")

        outer = tk.Frame(video_page, bg="#f4f1ea")
        outer.pack(fill="both", expand=True, padx=6, pady=6)

        left_wrapper = tk.Frame(outer, bg="#f4f1ea", width=500)
        left_wrapper.pack(side="left", fill="y", padx=(0, 12))
        left_wrapper.pack_propagate(False)

        right = tk.Frame(outer, bg="#f4f1ea")
        right.pack(side="right", fill="both", expand=True)

        title = tk.Label(left_wrapper, text=APP_NAME, font=("Segoe UI", 22, "bold"), bg="#f4f1ea", fg="#26211c")
        title.pack(anchor="w")

        subtitle = tk.Label(
            left_wrapper,
            text="Видео, подпись, плашка, watermark, фильтры, рандомизация и сохранение настроек",
            font=("Segoe UI", 9),
            bg="#f4f1ea",
            fg="#665f57",
            wraplength=460,
            justify="left",
        )
        subtitle.pack(anchor="w", pady=(2, 10))

        self.video_selector(left_wrapper)
        self.caption_box(left_wrapper)
        self.process_button(left_wrapper)
        self.settings_notebook(left_wrapper)
        self.settings_save_bar(left_wrapper)

        self.preview_area(right)
        self.log_area(right)

        self.photo_main_tab(photo_page)
        self.folders_main_tab(folders_page)

    def photo_main_tab(self, parent: tk.Widget) -> None:
        outer = tk.Frame(parent, bg="#f4f1ea")
        outer.pack(fill="both", expand=True, padx=6, pady=6)

        left_wrapper = tk.Frame(outer, bg="#f4f1ea", width=540)
        left_wrapper.pack(side="left", fill="y", padx=(0, 12))
        left_wrapper.pack_propagate(False)

        right = tk.Frame(outer, bg="#f4f1ea")
        right.pack(side="right", fill="both", expand=True)

        title = tk.Label(left_wrapper, text="Фото", font=("Segoe UI", 22, "bold"), bg="#f4f1ea", fg="#26211c")
        title.pack(anchor="w")
        subtitle = tk.Label(
            left_wrapper,
            text="Отдельная обработка фото: watermark, свет, цвет, эффекты, рандомизация и пресеты пабликов",
            font=("Segoe UI", 9),
            bg="#f4f1ea",
            fg="#665f57",
            wraplength=500,
            justify="left",
        )
        subtitle.pack(anchor="w", pady=(2, 10))

        self.photo_selector(left_wrapper)
        self.photo_process_button(left_wrapper)
        self.photo_settings_notebook(left_wrapper)
        self.settings_save_bar(left_wrapper)

        self.photo_preview_area(right)
        self.photo_log_area(right)

    def folders_main_tab(self, parent: tk.Widget) -> None:
        outer = tk.Frame(parent, bg="#f4f1ea")
        outer.pack(fill="both", expand=True, padx=14, pady=14)

        header = tk.Frame(outer, bg="#f4f1ea")
        header.pack(fill="x", pady=(0, 12))
        tk.Label(header, text="Папки", font=("Segoe UI", 24, "bold"), bg="#f4f1ea", fg="#26211c").pack(side="left")
        tk.Label(
            header,
            text="Отдельное место для исходников, готовых файлов, использованных, хлама и ресурсов",
            font=("Segoe UI", 10),
            bg="#f4f1ea",
            fg="#665f57",
        ).pack(side="left", padx=(14, 0), pady=(8, 0))

        grid = tk.Frame(outer, bg="#f4f1ea")
        grid.pack(fill="both", expand=True)
        grid.columnconfigure(0, weight=1)
        grid.columnconfigure(1, weight=1)
        grid.columnconfigure(2, weight=1)

        self.folder_section(
            grid,
            "Исходники",
            "Сюда кидаешь новые файлы для отбора и обработки",
            [
                ("Исходники видео", lambda: self.open_folder(PATHS["source_videos"]), "#e9dfd2", "#2e2924"),
                ("Исходники фото", lambda: self.open_folder(PATHS["source_photos"]), "#e9dfd2", "#2e2924"),
            ],
            row=0,
            column=0,
        )
        self.folder_section(
            grid,
            "Готовые",
            "Открывает готовые файлы выбранного паблика",
            [
                ("Готовые видео паблика", lambda: self.open_folder(self.public_output_folder("video")), "#2d7d46", "white"),
                ("Готовые фото паблика", lambda: self.open_folder(self.public_output_folder("photo")), "#2d6c9d", "white"),
                ("Папка выбранного паблика", lambda: self.open_folder(self.public_base_folder("video")), "#6b5b95", "white"),
            ],
            row=0,
            column=1,
        )
        self.folder_section(
            grid,
            "Использованные и хлам",
            "Туда бот переносит то, что уже обработано или не понравилось",
            [
                ("Использованные видео", lambda: self.open_folder(PATHS["used_videos"]), "#e9dfd2", "#2e2924"),
                ("Использованные фото", lambda: self.open_folder(PATHS["used_photos"]), "#e9dfd2", "#2e2924"),
                ("Хлам видео", lambda: self.open_folder(PATHS["trash_videos"]), "#b84a4a", "white"),
            ],
            row=0,
            column=2,
        )
        self.folder_section(
            grid,
            "Ресурсы",
            "Плашки, watermark, шрифты и музыка",
            [
                ("PNG плашки", lambda: self.open_folder(PATHS["plaques"]), "#e9dfd2", "#2e2924"),
                ("Watermark", lambda: self.open_folder(PATHS["watermarks"]), "#e9dfd2", "#2e2924"),
                ("Шрифты", lambda: self.open_folder(PATHS["fonts"]), "#e9dfd2", "#2e2924"),
                ("Музыка", lambda: self.open_folder(PATHS["music"]), "#e9dfd2", "#2e2924"),
            ],
            row=1,
            column=0,
        )
        self.folder_section(
            grid,
            "Паблики VK",
            "Все папки пабликов в одном месте",
            [
                ("Все паблики", lambda: self.open_folder(PATHS["publics"]), "#e9dfd2", "#2e2924"),
                ("Видео текущего паблика", lambda: self.open_folder(self.public_output_folder("video")), "#2d7d46", "white"),
                ("Фото текущего паблика", lambda: self.open_folder(self.public_output_folder("photo")), "#2d6c9d", "white"),
            ],
            row=1,
            column=1,
        )
        self.folder_section(
            grid,
            "Быстрые действия",
            "Самое частое для ежедневной работы",
            [
                ("Следующее видео из исходников", lambda: self.load_adjacent_video(1), "#e9dfd2", "#2e2924"),
                ("Обработать все видео", lambda: self.process_all_videos_from_folder_clicked(), "#2d7d46", "white"),
                ("Обновить музыку", lambda: self.refresh_music_choices(), "#e9dfd2", "#2e2924"),
            ],
            row=1,
            column=2,
        )

    def folder_section(self, parent: tk.Widget, title: str, hint: str, buttons: list[tuple[str, object, str, str]], row: int, column: int) -> None:
        box = self.card(parent)
        box.grid(row=row, column=column, sticky="nsew", padx=8, pady=8)
        tk.Label(box, text=title, font=("Segoe UI", 15, "bold"), bg="white", fg="#28231f").pack(anchor="w", padx=14, pady=(14, 4))
        tk.Label(box, text=hint, font=("Segoe UI", 9), bg="white", fg="#665f57", wraplength=360, justify="left").pack(anchor="w", padx=14, pady=(0, 10))
        for text, command, bg, fg in buttons:
            tk.Button(
                box,
                text=text,
                command=command,
                bg=bg,
                fg=fg,
                activebackground=bg,
                activeforeground=fg,
                relief="flat",
                font=("Segoe UI", 11, "bold" if fg == "white" else "normal"),
                height=2,
            ).pack(fill="x", padx=14, pady=4)

    def photo_settings_notebook(self, parent: tk.Widget) -> None:
        notebook = ttk.Notebook(parent)
        notebook.pack(fill="both", expand=True, pady=(0, 8))

        public_tab = self.scrollable_tab(notebook, "Паблики")
        self.public_controls(public_tab, "photo")

        folders_tab = self.scrollable_tab(notebook, "Папки")
        self.folder_big_buttons(folders_tab)

        text_tab = self.scrollable_tab(notebook, "Текст")
        self.photo_text_controls(text_tab)

        plaque_tab = self.scrollable_tab(notebook, "Плашка")
        self.photo_plaque_controls(plaque_tab)

        watermark_tab = self.scrollable_tab(notebook, "Watermark")
        self.photo_watermark_controls(watermark_tab)

        light_tab = self.scrollable_tab(notebook, "Свет")
        self.photo_filter_controls(light_tab, PHOTO_LIGHT_KEYS, "Свет")

        color_tab = self.scrollable_tab(notebook, "Цвет")
        self.photo_filter_controls(color_tab, PHOTO_COLOR_KEYS, "Цвет")

        effects_tab = self.scrollable_tab(notebook, "Эффекты")
        self.photo_filter_controls(effects_tab, PHOTO_EFFECT_KEYS, "Эффекты")

        random_tab = self.scrollable_tab(notebook, "Рандом фото")
        self.photo_random_controls(random_tab)

    def photo_selector(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="x", pady=(0, 8))

        header = tk.Frame(box, bg="white")
        header.pack(fill="x", padx=12, pady=(8, 3))
        tk.Label(header, text="Фото", font=("Segoe UI", 11, "bold"), bg="white", fg="#28231f").pack(side="left")
        tk.Label(header, textvariable=self.photo_label_var, bg="white", fg="#615950", font=("Segoe UI", 8), wraplength=360, justify="right").pack(side="right")

        row = tk.Frame(box, bg="white")
        row.pack(fill="x", padx=10, pady=(0, 8))
        tk.Button(row, text="Выбрать", command=self.choose_photo, bg="#eee6dc", relief="flat", height=1).pack(side="left", fill="x", expand=True, padx=(0, 4))
        tk.Button(row, text="Из папки", command=lambda: self.load_first_photo_from_folder(silent=False), bg="#eee6dc", relief="flat", height=1).pack(side="left", fill="x", expand=True, padx=(4, 0))

    def photo_caption_box(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="both", pady=(0, 10))

        tk.Label(box, text="Подпись для фото", font=("Segoe UI", 12, "bold"), bg="white", fg="#28231f").pack(anchor="w", padx=12, pady=(10, 6))
        self.photo_caption_text = tk.Text(box, height=3, wrap="word", font=("Segoe UI", 11), bd=0, bg="#fbf7f0", padx=8, pady=8, undo=True)
        self.photo_caption_text.pack(fill="both", expand=True, padx=10, pady=(0, 10))
        self.photo_caption_text.insert("1.0", self.config.get("photo_caption", "Лапы длинные, взгляд дорогой, характер царский"))
        self.photo_caption_text.bind("<KeyRelease>", lambda _e: self.on_settings_changed())
        self.add_text_edit_menu(self.photo_caption_text, editable=True, on_change=self.on_settings_changed)

    def photo_process_button(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="x", pady=(0, 10))

        tk.Button(
            box,
            text="Обработать фото",
            command=self.process_photo_clicked,
            bg="#2d7d46",
            fg="white",
            activebackground="#246b3a",
            activeforeground="white",
            font=("Segoe UI", 14, "bold"),
            height=2,
            relief="flat",
        ).pack(fill="x", padx=10, pady=(10, 8))
        ttk.Progressbar(box, variable=self.photo_progress_var, maximum=100).pack(fill="x", padx=10, pady=(0, 4))
        tk.Label(box, textvariable=self.photo_status_var, bg="white", fg="#615950", font=("Segoe UI", 9)).pack(anchor="w", padx=10, pady=(0, 8))

    def photo_preview_area(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="both", expand=True, pady=(0, 12))

        header = tk.Frame(box, bg="white")
        header.pack(fill="x", padx=14, pady=(10, 6))
        tk.Label(header, text="Предпросмотр фото", font=("Segoe UI", 14, "bold"), bg="white", fg="#28231f").pack(side="left")
        tk.Button(header, text="Обновить", command=self.update_photo_preview, bg="#eee6dc", relief="flat").pack(side="right")

        preview_frame = tk.Frame(box, bg="#1f1f1f")
        preview_frame.pack(fill="both", expand=True, padx=14, pady=(0, 14))
        self.photo_preview_label = tk.Label(preview_frame, text="Пока нет фото", bg="#1f1f1f", fg="white", font=("Segoe UI", 14))
        self.photo_preview_label.pack(fill="both", expand=True)

    def photo_log_area(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="x")
        tk.Label(box, text="Лог фото", font=("Segoe UI", 13, "bold"), bg="white", fg="#28231f").pack(anchor="w", padx=14, pady=(10, 6))
        self.photo_log_text = tk.Text(box, height=7, wrap="word", font=("Consolas", 9), bd=0, bg="#fbf7f0")
        self.photo_log_text.pack(fill="both", expand=True, padx=14, pady=(0, 14))
        self.add_text_edit_menu(self.photo_log_text, editable=False)
        self.photo_log("Фото модуль запущен")

    def photo_text_controls(self, parent: tk.Widget) -> None:
        box = self.card(parent)
        box.pack(fill="x", pady=(0, 10))

        tk.Label(box, text="Текст фото", font=("Segoe UI", 12, "bold"), bg="white", fg="#28231f").pack(anchor="w", padx=12, pady=(10, 8))
        self.slider_row(box, "Размер текста", self.photo_font_size_var, 18, 120)
        self.slider_row(box, "Межстрочный интервал", self.photo_line_spacing_var, 0, 50)
        self.slider_row(box, "Расстояние между буквами", self.photo_letter_spacing_var, 0, 24)
        self.slider_row(box, "Толщина букв", self.photo_text_weight_var, 0, 12)

        font_form = tk.Frame(box, bg="white")
        font_form.pack(fill="x", padx=12, pady=(4, 4))
        self.photo_font_combo = self.combo_row(font_form, 0, "Шрифт", self.photo_font_family_var, available_font_choices(), on_change=self.on_photo_font_family_changed)
        font_form.columnconfigure(1, weight=1)

        font_row = tk.Frame(box, bg="white")
        font_row.pack(fill="x", padx=10, pady=(0, 6))
        tk.Button(font_row, text="Выбрать файл шрифта", command=self.choose_photo_font_file, bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(0, 4))
        tk.Button(font_row, text="Очистить файл", command=self.clear_photo_font_file, bg="#eee6dc", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))
        tk.Label(box, textvariable=self.photo_font_label_var, bg="white", fg="#615950", font=("Segoe UI", 9), wraplength=480, justify="left").pack(anchor="w", padx=12, pady=(0, 6))

        self.slider_row(box, "Обводка текста", self.photo_text_stroke_var, 0, 10)
        self.check_row(box, "Тень под текстом", self.photo_text_shadow_var)

        form = tk.Frame(box, bg="white")
        form.pack(fill="x", padx=12, pady=(4, 8))
        self.combo_row(form, 0, "Горизонталь", self.photo_text_align_var, TEXT_ALIGNMENTS)
        self.combo_row(form, 1, "Вертикаль", self.photo_text_vertical_var, TEXT_VERTICALS)
        self.combo_row(form, 2, "Цвет текста", self.photo_text_color_var, list(TEXT_COLOR_DATA.keys()))
        form.columnconfigure(1, weight=1)

        color_row = tk.Frame(box, bg="white")
        color_row.pack(fill="x", padx=12, pady=(0, 8))
        tk.Label(color_row, text="Код цвета", bg="white", fg="#4d463f", font=("Segoe UI", 9)).pack(side="left", padx=(0, 8))
        color_entry = tk.Entry(color_row, textvariable=self.photo_text_custom_color_var, bg="#fbf7f0", bd=1, relief="solid")
        color_entry.pack(side="left", fill="x", expand=True, padx=(0, 6))
        color_entry.bind("<KeyRelease>", lambda _e: (self.photo_text_color_var.set("Свой код"), self.on_settings_changed()))
        color_entry.bind("<FocusOut>", lambda _e: (self.photo_text_color_var.set("Свой код"), self.on_settings_changed()))
        tk.Button(color_row, text="Палитра", command=self.choose_photo_text_color, bg="#eee6dc", relief="flat").pack(side="left")

        self.slider_row(box, "X текста внутри, %", self.photo_text_x_var, 0, 100)
        self.slider_row(box, "Y текста внутри, %", self.photo_text_y_var, 0, 100)

    def photo_plaque_controls(self, parent: tk.Widget) -> None:
