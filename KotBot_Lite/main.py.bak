        tk.Button(hint_row, text="Сгенерировать варианты", command=self.generate_ai_captions, bg="#2d7d46", fg="white", activebackground="#2d7d46", activeforeground="white", relief="flat", height=2).pack(side="left", fill="x", expand=True, padx=(4, 0))

