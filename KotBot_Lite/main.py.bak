    def card(self, parent: tk.Widget) -> tk.Frame:
        return tk.Frame(parent, bg="white", bd=0, highlightthickness=1, highlightbackground="#e1d8cc")

    def add_text_edit_menu(self, widget: tk.Text, editable: bool = True, on_change=None) -> None:
        """Нормальные Ctrl+C/V/X/A для Windows, включая русскую раскладку, и меню по правой кнопке."""
        menu = tk.Menu(widget, tearoff=0)

        def has_selection() -> bool:
            try:
                widget.index("sel.first")
                widget.index("sel.last")
                return True
            except tk.TclError:
                return False

        def finish_change() -> None:
            if on_change:
                self.root.after(10, on_change)

        def copy_text() -> str:
            if has_selection():
                text = widget.get("sel.first", "sel.last")
                self.root.clipboard_clear()
                self.root.clipboard_append(text)
            return "break"

        def cut_text() -> str:
            if editable and has_selection():
                copy_text()
                widget.delete("sel.first", "sel.last")
                finish_change()
            return "break"

        def paste_text() -> str:
            if editable:
                try:
                    text = self.root.clipboard_get()
                except tk.TclError:
                    return "break"
                if has_selection():
                    widget.delete("sel.first", "sel.last")
                widget.insert("insert", text)
                finish_change()
            return "break"

        def select_all() -> str:
            widget.tag_add("sel", "1.0", "end-1c")
            widget.mark_set("insert", "end-1c")
            widget.see("insert")
            return "break"

        def show_menu(event) -> str:
            widget.focus_set()
            menu.delete(0, "end")
            menu.add_command(label="Копировать", command=copy_text)
            if editable:
                menu.add_command(label="Вставить", command=paste_text)
                menu.add_command(label="Вырезать", command=cut_text)
            menu.add_separator()
            menu.add_command(label="Выделить всё", command=select_all)
            menu.tk_popup(event.x_root, event.y_root)
            return "break"

        def hotkey(event) -> str | None:
            # На русской раскладке Tkinter часто не видит Ctrl+V как Control-v.
            # Поэтому дополнительно проверяем Windows keycode букв A/C/V/X.
            key = str(event.keysym).lower()
            keycode = int(getattr(event, "keycode", 0) or 0)
            if key in {"c", "с"} or keycode == 67:
                return copy_text()
            if key in {"v", "м"} or keycode == 86:
                return paste_text()
            if key in {"x", "ч"} or keycode == 88:
                return cut_text()
            if key in {"a", "ф"} or keycode == 65:
                return select_all()
            return None

        widget.bind("<Control-KeyPress>", hotkey, add="+")
        widget.bind("<Control-c>", lambda _e: copy_text(), add="+")
        widget.bind("<Control-C>", lambda _e: copy_text(), add="+")
        widget.bind("<Control-v>", lambda _e: paste_text(), add="+")
        widget.bind("<Control-V>", lambda _e: paste_text(), add="+")
        widget.bind("<Control-x>", lambda _e: cut_text(), add="+")
        widget.bind("<Control-X>", lambda _e: cut_text(), add="+")
        widget.bind("<Control-a>", lambda _e: select_all(), add="+")
        widget.bind("<Control-A>", lambda _e: select_all(), add="+")
        widget.bind("<Command-c>", lambda _e: copy_text(), add="+")
        widget.bind("<Command-v>", lambda _e: paste_text(), add="+")
        widget.bind("<Command-x>", lambda _e: cut_text(), add="+")
        widget.bind("<Command-a>", lambda _e: select_all(), add="+")
        widget.bind("<Button-3>", show_menu, add="+")
        widget.bind("<Button-2>", show_menu, add="+")

    def slider_row(self, parent: tk.Widget, label: str, var: tk.IntVar, min_val: int, max_val: int) -> None:
        row = tk.Frame(parent, bg="white")
        row.pack(fill="x", padx=12, pady=3)

        top = tk.Frame(row, bg="white")
        top.pack(fill="x")
        tk.Label(top, text=label, bg="white", fg="#4d463f", font=("Segoe UI", 9)).pack(side="left")

        value_label = tk.Label(top, text=str(var.get()), bg="white", fg="#4d463f", font=("Segoe UI", 9), width=5)
        plus_btn = tk.Button(top, text="+", width=2, command=lambda: nudge(1), bg="#eee6dc", fg="#2e2924", relief="flat")
        minus_btn = tk.Button(top, text="-", width=2, command=lambda: nudge(-1), bg="#eee6dc", fg="#2e2924", relief="flat")
        plus_btn.pack(side="right", padx=(3, 0))
        value_label.pack(side="right")
        minus_btn.pack(side="right", padx=(0, 3))

        def update_label() -> None:
            value_label.config(text=str(int(var.get())))

        def changed(value):
            value_label.config(text=str(int(float(value))))
            self.on_settings_changed()

        def nudge(delta: int) -> None:
            var.set(clamp(int(var.get()) + delta, min_val, max_val))
            update_label()
            self.on_settings_changed()

        tk.Scale(
            row,
            from_=min_val,
            to=max_val,
            orient="horizontal",
            variable=var,
            command=changed,
            bg="white",
            highlightthickness=0,
            troughcolor="#eadfce",
            resolution=1,
        ).pack(fill="x")

    def combo_row(
        self,
        parent: tk.Widget,
        row_number: int,
        label: str,
        var: tk.StringVar,
        values: list[str],
        on_change=None,
    ) -> ttk.Combobox:
        tk.Label(parent, text=label, bg="white", fg="#4d463f", font=("Segoe UI", 9)).grid(row=row_number, column=0, sticky="w", pady=4, padx=(0, 8))
        combo = ttk.Combobox(parent, textvariable=var, values=values, state="readonly")
        combo.grid(row=row_number, column=1, sticky="ew", pady=4)

        def changed(_event=None):
            if on_change:
                on_change()
            else:
                self.on_settings_changed()

        combo.bind("<<ComboboxSelected>>", changed)
        return combo

    def check_row(self, parent: tk.Widget, label: str, var: tk.BooleanVar) -> None:
        cb = tk.Checkbutton(
            parent,
            text=label,
            variable=var,
            command=self.on_settings_changed,
            bg="white",
            fg="#4d463f",
            activebackground="white",
            font=("Segoe UI", 9),
            anchor="w",
        )
        cb.pack(fill="x", padx=10, pady=2)

    def get_caption(self) -> str:
        return self.caption_text.get("1.0", "end").strip()

    def active_media_tab(self) -> str | None:
        if not hasattr(self, "main_notebook"):
            return None
        try:
            title = self.main_notebook.tab(self.main_notebook.select(), "text")
            return "photo" if title == "Фото" else "video"
        except Exception:
            return None

    def schedule_config_save(self) -> None:
        if self._settings_save_after_id:
            try:
                self.root.after_cancel(self._settings_save_after_id)
            except Exception:
                pass
        self._settings_save_after_id = self.root.after(350, self.flush_config_save)

    def flush_config_save(self) -> None:
        self._settings_save_after_id = None
        self.save_config()

    def schedule_preview_update(self, media: str | None = None) -> None:
        media = media or self.active_media_tab()
        if media == "photo":
            if self._photo_preview_after_id:
                try:
                    self.root.after_cancel(self._photo_preview_after_id)
                except Exception:
                    pass
            self._photo_preview_after_id = self.root.after(260, self.flush_photo_preview_update)
        elif media == "video":
            if self._video_preview_after_id:
                try:
                    self.root.after_cancel(self._video_preview_after_id)
                except Exception:
                    pass
            self._video_preview_after_id = self.root.after(220, self.flush_video_preview_update)
        else:
            self.schedule_preview_update("video")
            self.schedule_preview_update("photo")

    def flush_video_preview_update(self) -> None:
        self._video_preview_after_id = None
        self.update_preview()

    def flush_photo_preview_update(self) -> None:
        self._photo_preview_after_id = None
        self.update_photo_preview()

    def on_settings_changed(self, preview: bool = True) -> None:
        if getattr(self, "_suspend_settings_events", False):
            return
        self.config["caption"] = self.get_caption() if hasattr(self, "caption_text") else self.config.get("caption", "")
        self.config["photo_caption"] = self.get_photo_caption()
        if hasattr(self, "font_label_var"):
            self.refresh_font_label()
        if hasattr(self, "photo_font_label_var"):
            self.refresh_photo_font_label()
        if hasattr(self, "music_label_var"):
            self.refresh_music_label()
        self.schedule_config_save()
        if preview:
            self.schedule_preview_update(self.active_media_tab())

    def save_settings_clicked(self) -> None:
        self.save_config()
        self.status_var.set("Настройки сохранены")
        self.log("Настройки сохранены в config.json")

    def on_plaque_position_changed(self) -> None:
        position = self.plaque_position_var.get()
        if position == "Сверху":
            self.plaque_y_var.set(18)
        elif position == "По центру":
            self.plaque_y_var.set(50)
        elif position == "Снизу":
            self.plaque_y_var.set(82)
        self.on_settings_changed()

    def reset_all_settings(self) -> None:
        if not messagebox.askyesno(APP_NAME, "Сбросить настройки текста, плашки, watermark, видео и рандома?"):
            return
        self.font_size_var.set(46)
        self.line_spacing_var.set(10)
        self.letter_spacing_var.set(0)
        self.text_weight_var.set(0)
        self.font_family_var.set("Segoe UI")
        self.font_file_path_var.set("")
        self.refresh_font_label()
        self.text_align_var.set("По центру")
        self.text_vertical_var.set("По центру")
        self.text_x_var.set(50)
        self.text_y_var.set(50)
        self.text_color_var.set("Авто")
        self.text_custom_color_var.set("#FFFFFF")
        self.text_stroke_var.set(0)
        self.text_shadow_var.set(False)

        self.plaque_enabled_var.set(True)
        self.plaque_position_var.set("Снизу")
        self.style_var.set("Кремовая")
        self.plaque_png_enabled_var.set(False)
        self.plaque_png_path_var.set("")
        self.plaque_cache_path = None
        self.plaque_cache_image = None
        self.refresh_plaque_png_label()
        self.plaque_x_var.set(50)
        self.plaque_y_var.set(82)
        self.plaque_width_var.set(72)
        self.plaque_height_var.set(18)
        self.plaque_opacity_var.set(92)
        self.plaque_radius_var.set(26)
        self.plaque_border_var.set(4)
        self.plaque_pad_x_var.set(8)
        self.plaque_pad_y_var.set(16)

        self.watermark_enabled_var.set(False)
        self.watermark_path_var.set("")
        self.watermark_size_var.set(16)
        self.watermark_opacity_var.set(75)
        self.watermark_position_var.set("Снизу справа")
        self.watermark_x_var.set(88)
        self.watermark_y_var.set(88)
        self.watermark_margin_var.set(4)
        self.watermark_cache_path = None
        self.watermark_cache_image = None
        self.refresh_watermark_label()

        self.brightness_var.set(0)
        self.contrast_var.set(100)
        self.saturation_var.set(100)
        self.sharpness_var.set(0)
        self.mirror_var.set(False)
        self.export_quality_var.set(85)
        self.video_scale_var.set(100)
        if hasattr(self, "preview_fast_var"):
            self.preview_fast_var.set(True)
        if hasattr(self, "vk_safe_zones_var"):
            self.vk_safe_zones_var.set(False)

        self.random_video_var.set(False)
        self.random_brightness_var.set(8)
        self.random_contrast_var.set(8)
        self.random_saturation_var.set(8)
        self.random_sharpness_var.set(6)
        self.random_video_scale_var.set(8)
        self.random_mirror_var.set(False)

        self.reset_photo_settings_values()

        self.on_settings_changed()
        self.status_var.set("Настройки сброшены")
        self.log("Настройки сброшены")

    def source_video_files(self) -> list[Path]:
        return sorted([p for p in PATHS["source_videos"].iterdir() if p.suffix.lower() in VIDEO_EXTS])

    def load_adjacent_video(self, delta: int) -> None:
        if self.processing:
            return
        files = self.source_video_files()
        if not files:
            messagebox.showinfo(APP_NAME, "В папке исходников видео пока нет файлов")
            return
        if self.selected_video and self.selected_video.resolve().parent == PATHS["source_videos"].resolve():
            try:
                idx = files.index(self.selected_video)
            except ValueError:
                idx = 0
            idx = (idx + delta) % len(files)
        else:
            idx = 0 if delta >= 0 else len(files) - 1
        self.selected_video = files[idx]
        self.video_label_var.set(self.selected_video.name)
        self.preview_playing = False
        self.close_preview_cap()
        self.load_frame_from_video(self.selected_video)
        self.update_preview()
        self.log(f"Выбрано видео из папки: {self.selected_video.name}")

    def process_all_videos_from_folder_clicked(self) -> None:
        if self.processing:
            messagebox.showinfo(APP_NAME, "Видео уже обрабатывается")
            return
        files = self.source_video_files()
        if not files:
            messagebox.showinfo(APP_NAME, "В папке исходников видео пока нет файлов")
            return
        if not messagebox.askyesno(APP_NAME, f"Обработать все видео из папки?\nФайлов: {len(files)}\nПаблик: {self.selected_public_name('video')}"):
            return
        self.video_batch_queue = list(files)
        self.video_batch_active = True
        self.process_next_video_in_batch()

    def process_next_video_in_batch(self) -> None:
        queue = getattr(self, "video_batch_queue", [])
        if not queue:
            self.video_batch_queue = []
            self.video_batch_active = False
            self.status_var.set("Пакетная обработка завершена")
            self.log("Пакетная обработка завершена")
            self.load_first_video_from_folder(silent=True)
            return
        self.selected_video = queue.pop(0)
        self.video_label_var.set(self.selected_video.name)
        self.log(f"Пакет: осталось после текущего {len(queue)}")
        self.process_video_clicked()

    def choose_video(self) -> None:
        path = filedialog.askopenfilename(
            title="Выбрать видео",
            filetypes=[("Видео", "*.mp4 *.mov *.avi *.mkv *.webm *.m4v"), ("Все файлы", "*.*")],
        )
        if not path:
            return
        self.selected_video = Path(path)
        self.video_label_var.set(self.selected_video.name)
        self.close_preview_cap()
        self.load_frame_from_video(self.selected_video)
        self.update_preview()
        self.log(f"Выбрано видео: {self.selected_video}")

    def load_first_video_from_folder(self, silent: bool = False) -> None:
        files = self.source_video_files()
        if not files:
            if not silent:
                messagebox.showinfo(APP_NAME, "В папке исходников видео пока нет файлов")
            return
        self.selected_video = files[0]
        self.video_label_var.set(self.selected_video.name)
        self.close_preview_cap()
        self.load_frame_from_video(self.selected_video)
        self.update_preview()
        if not silent:
            self.log(f"Взято видео из папки: {self.selected_video.name}")

    def load_frame_from_video(self, path: Path, frame_index: int | None = None) -> None:
        use_seek_cap = frame_index is not None
        cap = self.get_preview_seek_cap(path) if use_seek_cap else cv2.VideoCapture(str(path))
        if cap is None or not cap.isOpened():
            self.current_frame_bgr = None
            self.preview_frame_count = 0
            self.preview_duration = 0.0
            self.update_preview_seek_label(0)
            self.log(f"Ошибка: не удалось открыть видео {path.name}")
            return
        self.preview_frame_count = int(cap.get(cv2.CAP_PROP_FRAME_COUNT)) or 0
        self.preview_fps = float(cap.get(cv2.CAP_PROP_FPS) or 25.0)
        self.preview_duration = (self.preview_frame_count / self.preview_fps) if self.preview_frame_count > 0 and self.preview_fps > 0 else 0.0
        if frame_index is not None and self.preview_frame_count > 0:
            cap.set(cv2.CAP_PROP_POS_FRAMES, clamp(int(frame_index), 0, max(self.preview_frame_count - 1, 0)))
        ok, frame = cap.read()
        current_frame = int(cap.get(cv2.CAP_PROP_POS_FRAMES) or 0) - 1
        if not use_seek_cap:
            cap.release()
        if ok:
            self.current_frame_bgr = frame
            percent = int(current_frame * 100 / max(self.preview_frame_count - 1, 1)) if self.preview_frame_count > 1 else 0
            self.set_preview_seek(percent, current_frame)
        else:
            self.current_frame_bgr = None
            self.log(f"Ошибка: не удалось прочитать видео {path.name}")


    def on_font_family_changed(self) -> None:
        # Если пользователь выбрал шрифт из списка, внешний файл больше не перехватывает выбор.
        self.font_file_path_var.set("")
        self.refresh_font_label()
