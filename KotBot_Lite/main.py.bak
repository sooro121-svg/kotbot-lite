            self.photo_watermark_enabled_var.set(False)
            self.photo_watermark_path_var.set("")
            self.photo_watermark_size_var.set(16)
            self.photo_watermark_opacity_var.set(75)
            self.photo_watermark_position_var.set("Снизу справа")
            self.photo_watermark_x_var.set(88)
            self.photo_watermark_y_var.set(88)
            self.photo_watermark_margin_var.set(4)
            self.photo_watermark_cache_path = None
            self.photo_watermark_cache_image = None
            self.refresh_photo_watermark_label()

            self.photo_export_quality_var.set(92)
            self.photo_random_enabled_var.set(False)
            for key, (_label, _min_v, _max_v, default, random_default) in PHOTO_FILTER_SPECS.items():
                self.photo_filter_vars[key].set(default)
                self.photo_random_range_vars[key].set(random_default)

    def choose_photo(self) -> None:
        path = filedialog.askopenfilename(
            title="Выбрать фото",
            filetypes=[("Фото", "*.jpg *.jpeg *.png *.webp *.bmp"), ("Все файлы", "*.*")],
        )
        if not path:
            return
        self.selected_photo = Path(path)
        self.photo_label_var.set(self.selected_photo.name)
        self.load_image_from_photo(self.selected_photo)
        self.update_photo_preview()
        self.photo_log(f"Выбрано фото: {self.selected_photo}")

    def load_first_photo_from_folder(self, silent: bool = False) -> None:
        files = sorted([p for p in PATHS["source_photos"].iterdir() if p.suffix.lower() in PHOTO_EXTS])
        if not files:
            if not silent:
                messagebox.showinfo(APP_NAME, "В папке исходников фото пока нет файлов")
            return
        self.selected_photo = files[0]
        self.photo_label_var.set(self.selected_photo.name)
        self.load_image_from_photo(self.selected_photo)
        self.update_photo_preview()
        if not silent:
            self.photo_log(f"Взято фото из папки: {self.selected_photo.name}")

    def load_image_from_photo(self, path: Path) -> None:
        try:
            pil = Image.open(path).convert("RGB")
            rgb = np.array(pil)
            self.current_photo_bgr = cv2.cvtColor(rgb, cv2.COLOR_RGB2BGR)
        except Exception as exc:
            self.current_photo_bgr = None
            self.photo_log(f"Ошибка: не удалось прочитать фото {path.name}: {exc}") if hasattr(self, "photo_log_text") else None

    def update_photo_preview(self) -> None:
        if not hasattr(self, "photo_preview_label"):
            return
        if self.current_photo_bgr is None:
            self.photo_preview_label.configure(image="", text="Пока нет фото")
            return
        settings = self.collect_photo_settings(randomize=False)
        rendered = self.render_photo_bgr(
            self.current_photo_bgr,
            settings,
            watermark_image=self.load_photo_watermark_image(settings),
            plaque_image=self.load_photo_plaque_image(settings),
        )
        rgb = cv2.cvtColor(rendered, cv2.COLOR_BGR2RGB)
        img = Image.fromarray(rgb)
        img.thumbnail((920, 560), Image.Resampling.LANCZOS)
        photo = ImageTk.PhotoImage(img)
        self.photo_preview_image_ref = photo
        self.photo_preview_label.configure(image=photo, text="")

    def collect_photo_settings(self, randomize: bool = False) -> dict:
        settings = {
            "caption": self.get_photo_caption(),
            "font_size": self.photo_font_size_var.get(),
            "line_spacing": self.photo_line_spacing_var.get(),
            "text_weight": self.photo_text_weight_var.get(),
            "letter_spacing": self.photo_letter_spacing_var.get(),
            "font_family": self.photo_font_family_var.get(),
            "font_file_path": self.photo_font_file_path_var.get(),
            "text_align": self.photo_text_align_var.get(),
            "text_vertical": self.photo_text_vertical_var.get(),
            "text_x": self.photo_text_x_var.get(),
            "text_y": self.photo_text_y_var.get(),
            "text_color": self.photo_text_color_var.get(),
            "text_custom_color": self.photo_text_custom_color_var.get(),
            "text_stroke": self.photo_text_stroke_var.get(),
            "text_shadow": self.photo_text_shadow_var.get(),
            "plaque_enabled": self.photo_plaque_enabled_var.get(),
            "plaque_position": self.photo_plaque_position_var.get(),
            "style": self.photo_style_var.get(),
            "plaque_png_enabled": self.photo_plaque_png_enabled_var.get(),
            "plaque_png_path": self.photo_plaque_png_path_var.get(),
            "plaque_x": self.photo_plaque_x_var.get(),
            "plaque_y": self.photo_plaque_y_var.get(),
            "plaque_width": self.photo_plaque_width_var.get(),
            "plaque_height": self.photo_plaque_height_var.get(),
            "plaque_opacity": self.photo_plaque_opacity_var.get(),
            "plaque_radius": self.photo_plaque_radius_var.get(),
            "plaque_border": self.photo_plaque_border_var.get(),
            "plaque_pad_x": self.photo_plaque_pad_x_var.get(),
            "plaque_pad_y": self.photo_plaque_pad_y_var.get(),
            "watermark_enabled": self.photo_watermark_enabled_var.get(),
            "watermark_path": self.photo_watermark_path_var.get().strip(),
            "watermark_size": self.photo_watermark_size_var.get(),
            "watermark_opacity": self.photo_watermark_opacity_var.get(),
            "watermark_position": self.photo_watermark_position_var.get(),
            "watermark_x": self.photo_watermark_x_var.get(),
            "watermark_y": self.photo_watermark_y_var.get(),
            "watermark_margin": self.photo_watermark_margin_var.get(),
            "photo_export_quality": self.photo_export_quality_var.get(),
            "photo_random_enabled": self.photo_random_enabled_var.get(),
        }
        for key in PHOTO_FILTER_SPECS:
            settings[key] = self.photo_filter_vars[key].get()
            settings[f"random_{key}"] = self.photo_random_range_vars[key].get()
        if randomize:
            self.apply_photo_randomization(settings)
        return settings

    def apply_photo_randomization(self, settings: dict) -> None:
        used = {}
        if settings.get("photo_random_enabled"):
            for key, (_label, min_v, max_v, _default, _rand) in PHOTO_FILTER_SPECS.items():
                base = int(settings.get(key, 0))
                spread = int(settings.get(f"random_{key}", 0))
                final = clamp(base + random.randint(-spread, spread), min_v, max_v) if spread > 0 else base
                settings[key] = final
                used[key] = final
        settings["photo_random_used"] = used

    def process_photo_clicked(self) -> None:
        if self.photo_processing:
            messagebox.showinfo(APP_NAME, "Фото уже обрабатывается")
            return
        if not self.selected_photo:
            self.load_first_photo_from_folder(silent=True)
        if not self.selected_photo:
            messagebox.showinfo(APP_NAME, "Положи фото в папку исходников или выбери его кнопкой")
            return
        self.photo_worker_settings = self.collect_photo_settings(randomize=True)
        self.photo_worker_watermark_image = self.load_photo_watermark_image(self.photo_worker_settings)
        self.photo_worker_plaque_image = self.load_photo_plaque_image(self.photo_worker_settings)
        self.photo_progress_var.set(0)
        self.photo_processing = True
        thread = threading.Thread(target=self.process_photo_worker, daemon=True)
        thread.start()

    def process_photo_worker(self) -> None:
        source = self.selected_photo
        try:
            self.photo_safe_log(f"Старт обработки фото: {source.name}")
            self.photo_safe_log(f"Паблик VK: {self.selected_public_name('photo')}, папка: {self.public_output_folder('photo')}")
            self.photo_safe_status("Обработка фото...")
            self.photo_safe_progress(5)
            if self.photo_worker_settings and self.photo_worker_settings.get("photo_random_enabled"):
                used = self.photo_worker_settings.get("photo_random_used", {})
                if used:
                    names = []
                    for key, value in used.items():
                        label = PHOTO_FILTER_SPECS.get(key, (key,))[0]
                        names.append(f"{label}: {value}")
                    self.photo_safe_log("Рандом фото: " + "; ".join(names))

            pil = Image.open(source).convert("RGB")
            rgb = np.array(pil)
            bgr = cv2.cvtColor(rgb, cv2.COLOR_RGB2BGR)
            self.photo_safe_progress(20)
            rendered = self.render_photo_bgr(
                bgr,
                self.photo_worker_settings,
                watermark_image=self.photo_worker_watermark_image,
                plaque_image=self.photo_worker_plaque_image,
            )
            self.photo_safe_progress(75)

            output = self.next_public_output_file("photo", ".jpg")
            output.parent.mkdir(parents=True, exist_ok=True)
            out_rgb = cv2.cvtColor(rendered, cv2.COLOR_BGR2RGB)
            out_img = Image.fromarray(out_rgb).convert("RGB")
            quality = clamp(int(self.photo_worker_settings.get("photo_export_quality", 92)), 50, 100)
            out_img.save(output, quality=quality, optimize=True)
            self.photo_safe_progress(92)
            self.move_photo_source_if_safe(source)
            self.photo_safe_progress(100)
            self.photo_safe_log(f"Готово фото: {output}")
            self.photo_safe_status("Фото готово")
            self.root.after(0, lambda: messagebox.showinfo(APP_NAME, f"Готовое фото сохранено:\n{output}"))
        except Exception as exc:
            err = str(exc)
            self.photo_safe_log(f"Ошибка фото: {err}")
            self.photo_safe_status("Ошибка обработки фото")
            self.root.after(0, lambda e=err: messagebox.showerror(APP_NAME, f"Ошибка обработки фото:\n{e}"))
        finally:
            self.photo_processing = False
            self.photo_worker_watermark_image = None
            self.photo_worker_plaque_image = None
            self.root.after(0, self.after_photo_processing_refresh)

    def after_photo_processing_refresh(self) -> None:
        self.selected_photo = None
        self.current_photo_bgr = None
        self.photo_label_var.set("Фото не выбрано")
        self.load_first_photo_from_folder(silent=True)
        self.update_photo_preview()

    def move_photo_source_if_safe(self, source: Path) -> None:
        try:
            source_resolved = source.resolve()
            source_dir = PATHS["source_photos"].resolve()
            if source_resolved.parent != source_dir:
                self.photo_safe_log("Источник выбран вне папки source_photos, файл не перенесен")
                return
            target = unique_path(PATHS["used_photos"] / source.name)
            shutil.move(str(source), str(target))
            self.photo_safe_log(f"Исходник фото перенесен: {target.name}")
        except Exception as exc:
            self.photo_safe_log(f"Не удалось перенести исходник фото: {exc}")

    def render_photo_bgr(self, frame_bgr: np.ndarray, settings: dict, watermark_image: Image.Image | None = None, plaque_image: Image.Image | None = None) -> np.ndarray:
        adjusted = self.apply_photo_filters(frame_bgr, settings)
        rgb = cv2.cvtColor(adjusted, cv2.COLOR_BGR2RGB)
        image = Image.fromarray(rgb).convert("RGBA")
        image = self.draw_caption_plaque(image, settings, plaque_image)
        image = self.draw_watermark(image, settings, watermark_image)
        return cv2.cvtColor(np.array(image.convert("RGB")), cv2.COLOR_RGB2BGR)

    def apply_photo_filters(self, frame_bgr: np.ndarray, settings: dict) -> np.ndarray:
        rgb = cv2.cvtColor(frame_bgr, cv2.COLOR_BGR2RGB).astype(np.float32) / 255.0

        exposure = float(settings.get("exposure", 0))
        if exposure:
            rgb *= 2.0 ** (exposure / 100.0)

        contrast = float(settings.get("photo_contrast", 0))
        if contrast:
            factor = 1.0 + contrast / 100.0
            rgb = (rgb - 0.5) * factor + 0.5

        rgb = np.clip(rgb, 0, 1)
        lum = (rgb[:, :, 0] * 0.2126 + rgb[:, :, 1] * 0.7152 + rgb[:, :, 2] * 0.0722)[:, :, None]

        highlights = float(settings.get("highlights", 0)) / 100.0
        if highlights:
            mask = np.clip((lum - 0.45) / 0.55, 0, 1) ** 1.4
            rgb += highlights * mask * (0.35 if highlights > 0 else 0.28) * (1 - rgb if highlights > 0 else rgb)

        shadows = float(settings.get("shadows", 0)) / 100.0
        if shadows:
            mask = np.clip((0.65 - lum) / 0.65, 0, 1) ** 1.2
            rgb += shadows * mask * (0.35 if shadows > 0 else 0.28) * (1 - rgb if shadows > 0 else rgb)

        whites = float(settings.get("whites", 0)) / 100.0
        if whites:
            mask = np.clip((lum - 0.65) / 0.35, 0, 1) ** 1.1
            rgb += whites * mask * 0.25

        blacks = float(settings.get("blacks", 0)) / 100.0
        if blacks:
            mask = np.clip((0.45 - lum) / 0.45, 0, 1) ** 1.1
            rgb += blacks * mask * 0.25

        temperature = float(settings.get("temperature", 0)) / 100.0
        if temperature:
            rgb[:, :, 0] += temperature * 0.10
            rgb[:, :, 2] -= temperature * 0.10

        tint = float(settings.get("tint", 0)) / 100.0
        if tint:
            rgb[:, :, 0] += tint * 0.06
            rgb[:, :, 2] += tint * 0.06
            rgb[:, :, 1] -= tint * 0.08

        rgb = np.clip(rgb, 0, 1)
        rgb = apply_saturation_like(rgb, float(settings.get("photo_saturation", 0)), float(settings.get("vibrance", 0)))

        texture = float(settings.get("texture", 0)) / 100.0
        if texture:
            blur = cv2.GaussianBlur(rgb, (0, 0), 0.7)
            rgb = rgb + (rgb - blur) * texture * 0.45

        clarity = float(settings.get("clarity", 0)) / 100.0
        if clarity:
            blur = cv2.GaussianBlur(rgb, (0, 0), 2.2)
            rgb = rgb + (rgb - blur) * clarity * 0.55

        dehaze = float(settings.get("dehaze", 0)) / 100.0
        if dehaze:
            rgb = (rgb - 0.5) * (1.0 + dehaze * 0.45) + 0.5 - dehaze * 0.04

        vignette = float(settings.get("vignette", 0)) / 100.0
        if vignette:
            yy, xx = np.mgrid[0:rgb.shape[0], 0:rgb.shape[1]]
            cx = (rgb.shape[1] - 1) / 2.0
            cy = (rgb.shape[0] - 1) / 2.0
            dist = np.sqrt(((xx - cx) / max(cx, 1)) ** 2 + ((yy - cy) / max(cy, 1)) ** 2)
            edge = np.clip((dist - 0.25) / 0.9, 0, 1)[:, :, None]
            if vignette > 0:
                rgb *= (1.0 - edge * vignette * 0.65)
            else:
                rgb += edge * (-vignette) * 0.35 * (1 - rgb)

        grain = float(settings.get("grain", 0))
        if grain > 0:
            noise = np.random.normal(0, grain / 100.0 * 0.07, rgb.shape).astype(np.float32)
            rgb += noise

        rgb = np.clip(rgb, 0, 1)
        out = (rgb * 255).astype(np.uint8)
        return cv2.cvtColor(out, cv2.COLOR_RGB2BGR)

    def load_photo_plaque_image(self, settings: dict | None = None) -> Image.Image | None:
        if settings is None:
            settings = self.collect_photo_settings(randomize=False)
        if not settings.get("plaque_png_enabled"):
            return None
        path_text = str(settings.get("plaque_png_path", "")).strip()
        if not path_text:
            return None
        path = Path(path_text)
        if not path.exists():
            return None
        try:
            if self.photo_plaque_cache_path == path and self.photo_plaque_cache_image is not None:
                return self.photo_plaque_cache_image
            img = Image.open(path).convert("RGBA")
            self.photo_plaque_cache_path = path
            self.photo_plaque_cache_image = img
            return img
        except Exception as exc:
            self.photo_log(f"Ошибка PNG плашки фото: {exc}") if hasattr(self, "photo_log_text") else None
            return None

    def load_photo_watermark_image(self, settings: dict | None = None) -> Image.Image | None:
        if settings is None:
            settings = self.collect_photo_settings(randomize=False)
        if not settings.get("watermark_enabled"):
            return None
        path_text = str(settings.get("watermark_path", "")).strip()
        if not path_text:
            return None
        path = Path(path_text)
        if not path.exists():
            return None
        try:
            if self.photo_watermark_cache_path == path and self.photo_watermark_cache_image is not None:
                return self.photo_watermark_cache_image
            img = Image.open(path).convert("RGBA")
            self.photo_watermark_cache_path = path
            self.photo_watermark_cache_image = img
            return img
        except Exception as exc:
            self.photo_log(f"Ошибка watermark фото: {exc}") if hasattr(self, "photo_log_text") else None
            return None

    def photo_safe_log(self, message: str) -> None:
        self.root.after(0, lambda: self.photo_log(message))

    def photo_safe_progress(self, value: int) -> None:
        self.root.after(0, lambda v=value: self.photo_progress_var.set(clamp(v, 0, 100)))

    def photo_safe_status(self, message: str) -> None:
        self.root.after(0, lambda: self.photo_status_var.set(message))

    def photo_log(self, message: str) -> None:
        if not hasattr(self, "photo_log_text"):
            return
        stamp = time.strftime("%H:%M:%S")
        self.photo_log_text.insert("end", f"[{stamp}] {message}\n")
        self.photo_log_text.see("end")

    def open_folder(self, path: Path) -> None:
        path.mkdir(parents=True, exist_ok=True)
        try:
            if platform.system() == "Windows":
                os.startfile(str(path))
            elif platform.system() == "Darwin":
                subprocess.run(["open", str(path)], check=False)
            else:
                subprocess.run(["xdg-open", str(path)], check=False)
        except Exception as exc:
            self.log(f"Не удалось открыть папку: {exc}")

    def safe_log(self, message: str) -> None:
        self.root.after(0, lambda: self.log(message))

    def safe_progress(self, value: int) -> None:
        self.root.after(0, lambda v=value: self.progress_var.set(clamp(v, 0, 100)))

    def safe_status(self, message: str) -> None:
        self.root.after(0, lambda: self.status_var.set(message))

    def log(self, message: str) -> None:
        stamp = time.strftime("%H:%M:%S")
        self.log_text.insert("end", f"[{stamp}] {message}\n")
        self.log_text.see("end")

    def on_close(self) -> None:
        self.preview_playing = False
        if self.preview_after_id:
            try:
                self.root.after_cancel(self.preview_after_id)
            except Exception:
                pass
        if self.preview_seek_after_id:
            try:
                self.root.after_cancel(self.preview_seek_after_id)
            except Exception:
                pass
        self.close_preview_cap()
        self.save_config()
        self.root.destroy()


def format_time(seconds: float) -> str:
    seconds = max(0, int(seconds or 0))
    minutes = seconds // 60
    sec = seconds % 60
    return f"{minutes:02d}:{sec:02d}"

def apply_saturation_like(rgb: np.ndarray, saturation_value: float = 0, vibrance_value: float = 0) -> np.ndarray:
    rgb = np.clip(rgb, 0, 1).astype(np.float32)
    hsv = cv2.cvtColor((rgb * 255).astype(np.uint8), cv2.COLOR_RGB2HSV).astype(np.float32)
    sat = hsv[:, :, 1] / 255.0
    if saturation_value:
        factor = 1.0 + saturation_value / 100.0
        sat = np.clip(sat * factor, 0, 1)
    if vibrance_value:
        vib = vibrance_value / 100.0
        sat = np.clip(sat * (1.0 + vib * (1.0 - sat) * 1.4), 0, 1)
    hsv[:, :, 1] = sat * 255.0
    out = cv2.cvtColor(np.clip(hsv, 0, 255).astype(np.uint8), cv2.COLOR_HSV2RGB).astype(np.float32) / 255.0
    return out


def unique_path(path: Path) -> Path:
    if not path.exists():
        return path
    stem = path.stem
    suffix = path.suffix
    parent = path.parent
    counter = 2
    while True:
        new_path = parent / f"{stem}_{counter}{suffix}"
        if not new_path.exists():
            return new_path
        counter += 1


def slugify_public_name(name: str) -> str:
    translit = {
        "а": "a", "б": "b", "в": "v", "г": "g", "д": "d", "е": "e", "ё": "e", "ж": "zh", "з": "z",
        "и": "i", "й": "y", "к": "k", "л": "l", "м": "m", "н": "n", "о": "o", "п": "p", "р": "r",
        "с": "s", "т": "t", "у": "u", "ф": "f", "х": "h", "ц": "c", "ч": "ch", "ш": "sh", "щ": "sch",
        "ъ": "", "ы": "y", "ь": "", "э": "e", "ю": "yu", "я": "ya",
    }
    result = []
    for ch in str(name or "").lower():
        if ch in translit:
            result.append(translit[ch])
        elif ch.isalnum():
            result.append(ch)
        elif ch in (" ", "-", "_", "."):
            result.append("_")
    slug = "".join(result)
    while "__" in slug:
        slug = slug.replace("__", "_")
    return slug.strip("._-")[:60] or "public"

def safe_filename(name: str) -> str:
    keep = []
    for ch in name:
        if ch.isalnum() or ch in ("_", "-", "."):
            keep.append(ch)
        else:
            keep.append("_")
    result = "".join(keep).strip("._")
    return result[:80] or "video"


def clamp(value, min_value, max_value):
    return max(min_value, min(max_value, value))


def yes_no(value) -> str:
    return "да" if value else "нет"


def apply_alpha(color: tuple[int, int, int, int], opacity_pct: int) -> tuple[int, int, int, int]:
    r, g, b, a = color
    return (r, g, b, int(a * clamp(opacity_pct, 0, 100) / 100))


def parse_color_code(value: str) -> tuple[int, int, int, int] | None:
    text = str(value or "").strip()
    if not text:
        return None
    if text.startswith("#"):
        text = text[1:]
    if len(text) == 3 and all(ch in "0123456789abcdefABCDEF" for ch in text):
        text = "".join(ch * 2 for ch in text)
    if len(text) == 6 and all(ch in "0123456789abcdefABCDEF" for ch in text):
        return (int(text[0:2], 16), int(text[2:4], 16), int(text[4:6], 16), 255)

    lowered = text.lower().replace("rgb", "").replace("(", "").replace(")", "")
    parts = [part.strip() for part in lowered.replace(";", ",").split(",") if part.strip()]
    if len(parts) >= 3:
        try:
            r, g, b = [clamp(int(float(part)), 0, 255) for part in parts[:3]]
            return (r, g, b, 255)
        except Exception:
            return None
    return None


def resolve_text_color(settings: dict, style: dict) -> tuple[int, int, int, int]:
    color_name = settings.get("text_color", "Авто")
    if color_name == "Свой код":
        parsed = parse_color_code(settings.get("text_custom_color", ""))
        if parsed is not None:
            return parsed
    return TEXT_COLOR_DATA.get(color_name) or style["text"]


def effective_text_weight(weight: int) -> int:
    weight = clamp(int(weight), 0, 20)
    if weight <= 0:
        return 0
    # На многих декоративных шрифтах 1-3 пикселя почти не видно.
    # Поэтому ползунок начинается заметно уже с 1, но 0 остается полностью обычным.
    return clamp(weight + 1, 2, 24)


def _draw_text_no_spacing(
    draw: ImageDraw.ImageDraw,
    xy: tuple[int, int],
    text: str,
    font,
    fill: tuple[int, int, int, int],
    stroke_width: int,
    stroke_fill: tuple[int, int, int, int],
    weight: int = 0,
) -> None:
    weight = effective_text_weight(weight)
    stroke_width = max(0, int(stroke_width))
    x, y = xy
    if weight <= 0:
        draw.text((x, y), text, font=font, fill=fill, stroke_width=stroke_width, stroke_fill=stroke_fill)
        return
    if stroke_width > 0:
        draw.text((x, y), text, font=font, fill=fill, stroke_width=stroke_width + weight, stroke_fill=stroke_fill)
        draw.text((x, y), text, font=font, fill=fill, stroke_width=weight, stroke_fill=fill)
    else:
        draw.text((x, y), text, font=font, fill=fill, stroke_width=weight, stroke_fill=fill)


def draw_weighted_text(
    draw: ImageDraw.ImageDraw,
    xy: tuple[int, int],
    text: str,
    font,
    fill: tuple[int, int, int, int],
    stroke_width: int,
    stroke_fill: tuple[int, int, int, int],
    weight: int = 0,
    letter_spacing: int = 0,
) -> None:
    letter_spacing = max(0, int(letter_spacing))
    if letter_spacing <= 0 or len(text) <= 1:
        _draw_text_no_spacing(draw, xy, text, font, fill, stroke_width, stroke_fill, weight)
        return

    x, y = xy
    cursor_x = x
    for ch in text:
        _draw_text_no_spacing(draw, (cursor_x, y), ch, font, fill, stroke_width, stroke_fill, weight)
        cursor_x += glyph_width(draw, ch, font, stroke_width) + letter_spacing

def best_stroke_color(text_fill: tuple[int, int, int, int]) -> tuple[int, int, int, int]:
    r, g, b, _a = text_fill
    luminance = 0.2126 * r + 0.7152 * g + 0.0722 * b
    if luminance > 150:
        return (0, 0, 0, 180)
    return (255, 255, 255, 180)


def available_font_choices() -> list[str]:
    choices = list(FONT_FAMILIES)
    font_dir = DATA_DIR / "fonts"
    try:
        for path in sorted(font_dir.iterdir()):
            if path.suffix.lower() in FONT_EXTS:
                name = f"Файл: {path.stem}"
                if name not in choices:
                    choices.append(name)
    except Exception:
        pass
    return choices


def resolve_font_file(font_family: str = "Segoe UI", font_file_path: str = "") -> Path | None:
    path_text = str(font_file_path or "").strip()
    if path_text:
        path = Path(path_text)
        if path.exists() and path.suffix.lower() in FONT_EXTS:
            return path

    family = str(font_family or "Segoe UI").strip()
    if family.startswith("Файл: "):
        wanted = family.replace("Файл: ", "", 1).strip().lower()
        for folder in [DATA_DIR / "fonts", BASE_DIR / "assets"]:
            try:
                for path in folder.iterdir():
                    if path.suffix.lower() in FONT_EXTS and path.stem.lower() == wanted:
                        return path
            except Exception:
                pass

    if platform.system() == "Windows":
        windir = os.environ.get("WINDIR", r"C:\Windows")
        fonts_dir = Path(windir) / "Fonts"
        windows_fonts = {
            "Segoe UI": "segoeui.ttf",
            "Arial": "arial.ttf",
            "Tahoma": "tahoma.ttf",
            "Verdana": "verdana.ttf",
            "Georgia": "georgia.ttf",
            "Times New Roman": "times.ttf",
            "Comic Sans MS": "comic.ttf",
            "Impact": "impact.ttf",
            "Courier New": "cour.ttf",
        }
        filename = windows_fonts.get(family)
        if filename:
            path = fonts_dir / filename
            if path.exists():
                return path

    linux_fonts = {
        "DejaVu Sans": Path("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"),
        "DejaVu Sans Bold": Path("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"),
    }
    path = linux_fonts.get(family)
    if path and path.exists():
        return path

    for path in [
        BASE_DIR / "assets" / "font.ttf",
        DATA_DIR / "fonts" / "font.ttf",
        Path("/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"),
        Path("/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf"),
    ]:
        try:
            if path.exists():
                return path
        except Exception:
            continue
    return None


def load_font(size: int, font_family: str = "Segoe UI", font_file_path: str = "") -> ImageFont.FreeTypeFont | ImageFont.ImageFont:
    path = resolve_font_file(font_family, font_file_path)
    if path is not None:
        try:
            return ImageFont.truetype(str(path), size=size)
        except Exception:
            pass

    try:
        return ImageFont.truetype(str(font_family), size=size)
    except Exception:
        return ImageFont.load_default()

def glyph_width(draw: ImageDraw.ImageDraw, text: str, font, stroke_width: int = 0) -> int:
    bbox = draw.textbbox((0, 0), text or " ", font=font, stroke_width=stroke_width)
    return max(0, bbox[2] - bbox[0])


def text_width(draw: ImageDraw.ImageDraw, text: str, font, stroke_width: int = 0, letter_spacing: int = 0) -> int:
    letter_spacing = max(0, int(letter_spacing))
    if not text:
        return 0
    if letter_spacing <= 0 or len(text) <= 1:
        return glyph_width(draw, text, font, stroke_width)
    return sum(glyph_width(draw, ch, font, stroke_width) for ch in text) + letter_spacing * (len(text) - 1)


def text_height(draw: ImageDraw.ImageDraw, text: str, font, stroke_width: int = 0) -> int:
    bbox = draw.textbbox((0, 0), text or "Ay", font=font, stroke_width=stroke_width)
    return bbox[3] - bbox[1]


def text_block_height(draw: ImageDraw.ImageDraw, lines: list[str], font, line_spacing: int, stroke_width: int = 0) -> int:
    if not lines:
        return 0
    heights = [text_height(draw, line, font, stroke_width) for line in lines]
    return sum(heights) + line_spacing * max(0, len(lines) - 1)


def wrap_text(draw: ImageDraw.ImageDraw, text: str, font, max_width: int, stroke_width: int = 0, letter_spacing: int = 0) -> list[str]:
    final_lines = []
    for raw_line in text.splitlines() or [text]:
        words = raw_line.split()
        if not words:
            final_lines.append("")
            continue
        line = ""
        for word in words:
            candidate = word if not line else f"{line} {word}"
            if text_width(draw, candidate, font, stroke_width, letter_spacing) <= max_width:
                line = candidate
            else:
                if line:
                    final_lines.append(line)
                    line = ""
                if text_width(draw, word, font, stroke_width, letter_spacing) <= max_width:
                    line = word
                else:
                    pieces = split_long_word(draw, word, font, max_width, stroke_width, letter_spacing)
                    final_lines.extend(pieces[:-1])
                    line = pieces[-1]
        if line:
            final_lines.append(line)
    return final_lines or [""]


def split_long_word(draw: ImageDraw.ImageDraw, word: str, font, max_width: int, stroke_width: int = 0, letter_spacing: int = 0) -> list[str]:
    parts = []
    current = ""
    for ch in word:
        candidate = current + ch
        if text_width(draw, candidate, font, stroke_width, letter_spacing) <= max_width:
            current = candidate
        else:
            if current:
                parts.append(current)
            current = ch
    if current:
        parts.append(current)
    return parts or [word]


def trim_line(draw: ImageDraw.ImageDraw, line: str, font, max_width: int, stroke_width: int = 0, letter_spacing: int = 0) -> str:
    if text_width(draw, line, font, stroke_width, letter_spacing) <= max_width:
        return line
    ellipsis = "..."
    while line and text_width(draw, line + ellipsis, font, stroke_width, letter_spacing) > max_width:
        line = line[:-1]
    return line + ellipsis


if __name__ == "__main__":
    root = tk.Tk()
    app = KotBotApp(root)
    root.mainloop()
