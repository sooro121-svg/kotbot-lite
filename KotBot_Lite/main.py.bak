        self.text_color_var = tk.StringVar(value=self.config.get("text_color", "Авто"))
        if self.text_color_var.get() not in TEXT_COLOR_DATA:
            self.text_color_var.set("Авто")
        self.text_custom_color_var = tk.StringVar(value=self.config.get("text_custom_color", "#FFFFFF"))
        self.text_stroke_var = tk.IntVar(value=int(self.config.get("text_stroke", 0)))
        self.text_shadow_var = tk.BooleanVar(value=bool(self.config.get("text_shadow", False)))

        self.plaque_enabled_var = tk.BooleanVar(value=bool(self.config.get("plaque_enabled", True)))
